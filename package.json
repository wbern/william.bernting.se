{
  "name": "site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:update": "playwright test --update-snapshots",
    "print:preview": "tsx scripts/print-preview.ts",
    "print:preview:dev": "tsx scripts/print-preview.ts --dev",
    "cv:preview": "tsx scripts/print-preview.ts --page=/cv",
    "cv:preview:dev": "tsx scripts/print-preview.ts --dev --page=/cv"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.0.8",
    "keen-slider": "^6.8.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  }
}