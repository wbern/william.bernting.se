---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Projects from "../components/Projects.astro";
import Stats from "../components/Stats.astro";
import Traits from "../components/Traits.astro";
import Timeline from "../components/Timeline.astro";
import Skills from "../components/Skills.astro";
import Quote from "../components/Quote.astro";
import PdfButton from "../components/PdfButton.astro";
import SlideDots from "../components/SlideDots.astro";
---

<Layout title="William Bernting">
    <div id="slider" class="keen-slider">
        <div class="keen-slider__slide">
            <Hero />
        </div>
        <div class="keen-slider__slide">
            <Projects />
        </div>
        <div class="keen-slider__slide">
            <Stats />
        </div>
        <div class="keen-slider__slide">
            <Traits />
        </div>
        <div class="keen-slider__slide">
            <Timeline />
        </div>
        <div class="keen-slider__slide">
            <Skills />
        </div>
        <div class="keen-slider__slide section-quote">
            <Quote />
        </div>
    </div>

    <SlideDots count={7} />
    <PdfButton />
</Layout>

<script>
    import KeenSlider from "keen-slider";

    // Mousewheel plugin for keen-slider
    function WheelControls(slider: any) {
        let touchTimeout: ReturnType<typeof setTimeout>;
        let position: { x: number; y: number };
        let wheelActive: boolean;

        function currentSlideEl(): HTMLElement | null {
            const idx = slider.track.details.rel;
            return slider.slides[idx] ?? null;
        }

        function slideCanScroll(el: HTMLElement, deltaY: number): boolean {
            const tolerance = 1;
            if (deltaY > 0) {
                // scrolling down — room below?
                return el.scrollTop + el.clientHeight < el.scrollHeight - tolerance;
            }
            // scrolling up — room above?
            return el.scrollTop > tolerance;
        }

        function dispatch(e: WheelEvent, name: string) {
            position.x -= e.deltaX;
            position.y -= e.deltaY;
            slider.container.dispatchEvent(
                new CustomEvent(name, {
                    detail: { x: position.x, y: position.y },
                })
            );
        }

        function wheelStart(e: WheelEvent) {
            position = { x: e.pageX, y: e.pageY };
            dispatch(e, "ksDragStart");
        }

        function wheel(e: WheelEvent) {
            dispatch(e, "ksDrag");
        }

        function wheelEnd(e: WheelEvent) {
            dispatch(e, "ksDragEnd");
        }

        slider.on("created", () => {
            slider.container.addEventListener(
                "wheel",
                (e: WheelEvent) => {
                    const slide = currentSlideEl();
                    if (slide && slideCanScroll(slide, e.deltaY)) {
                        // Let the browser scroll within the slide
                        return;
                    }

                    e.preventDefault();
                    if (!wheelActive) {
                        wheelStart(e);
                        wheelActive = true;
                    }
                    wheel(e);
                    clearTimeout(touchTimeout);
                    touchTimeout = setTimeout(() => {
                        wheelActive = false;
                        wheelEnd(e);
                    }, 50);
                },
                { passive: false }
            );
        });
    }

    // Reveal animations for current slide
    function revealSlide(index: number) {
        const slides = document.querySelectorAll(".keen-slider__slide");
        slides.forEach((slide, i) => {
            const reveals = slide.querySelectorAll(".reveal");
            if (i === index) {
                reveals.forEach((el) => el.classList.add("visible"));
            } else {
                reveals.forEach((el) => el.classList.remove("visible"));
            }
        });
    }

    // Update dot navigation
    function updateDots(index: number) {
        const dots = document.querySelectorAll(".slide-dot");
        dots.forEach((dot, i) => {
            dot.classList.toggle("active", i === index);
        });
    }

    // Initialize slider
    const sliderEl = document.getElementById("slider");
    if (sliderEl) {
        const slider = new KeenSlider(
            sliderEl,
            {
                vertical: true,
                slides: { perView: 1 },
                defaultAnimation: { duration: 800 },
                detailsChanged: (s) => {
                    const slideIndex = s.track.details.rel;
                    updateDots(slideIndex);
                },
                animationEnded: (s) => {
                    revealSlide(s.track.details.rel);
                },
                created: () => {
                    // Reveal first slide immediately
                    revealSlide(0);
                },
            },
            [WheelControls]
        );

        // Dot click navigation
        document.querySelectorAll(".slide-dot").forEach((dot) => {
            dot.addEventListener("click", () => {
                const slideIndex = Number(
                    (dot as HTMLElement).dataset.slide
                );
                slider.moveToIdx(slideIndex);
            });
        });

        // Keyboard navigation
        document.addEventListener("keydown", (e) => {
            if (e.key === "ArrowDown" || e.key === "PageDown") {
                e.preventDefault();
                slider.next();
            } else if (e.key === "ArrowUp" || e.key === "PageUp") {
                e.preventDefault();
                slider.prev();
            }
        });
    }
</script>
