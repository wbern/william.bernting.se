---
import { defaultLang, type Lang } from "../i18n/ui";

const currentLang = (Astro.currentLocale ?? defaultLang) as Lang;
const pathname = Astro.url.pathname;

// Compute alternate-language path
const altPath =
  currentLang === "en"
    ? pathname.replace(/^\/en\/?/, "/") || "/"
    : pathname === "/"
      ? "/en/"
      : `/en${pathname}`;
---

<nav class="lang-picker" aria-label="Language">
  {currentLang === "sv" ? (
    <span class="lang-flag active" aria-current="true" aria-label="Svenska">
      <svg viewBox="0 0 640 480" aria-hidden="true"><path fill="#005baa" d="M0 0h640v480H0z"/><path fill="#fecb00" d="M176 0h80v480h-80z"/><path fill="#fecb00" d="M0 200h640v80H0z"/></svg>
    </span>
    <a href={altPath} class="lang-flag" aria-label="English">
      <svg viewBox="0 0 640 480" aria-hidden="true"><path fill="#012169" d="M0 0h640v480H0z"/><path fill="#fff" d="m75 0 244 181L562 0h78v62L400 241l240 178v61h-80L320 301 81 480H0v-60l239-178L0 64V0z"/><path fill="#c8102e" d="m424 281 216 159v40L369 281zm-184 20 6 35L54 480H0zM640 0v3L391 191l2-44L590 0zM0 0l239 176h-60L0 42z"/><path fill="#fff" d="M241 0v480h160V0zM0 160v160h640V160z"/><path fill="#c8102e" d="M0 193v96h640v-96zM273 0v480h96V0z"/></svg>
    </a>
  ) : (
    <a href={altPath} class="lang-flag" aria-label="Svenska">
      <svg viewBox="0 0 640 480" aria-hidden="true"><path fill="#005baa" d="M0 0h640v480H0z"/><path fill="#fecb00" d="M176 0h80v480h-80z"/><path fill="#fecb00" d="M0 200h640v80H0z"/></svg>
    </a>
    <span class="lang-flag active" aria-current="true" aria-label="English">
      <svg viewBox="0 0 640 480" aria-hidden="true"><path fill="#012169" d="M0 0h640v480H0z"/><path fill="#fff" d="m75 0 244 181L562 0h78v62L400 241l240 178v61h-80L320 301 81 480H0v-60l239-178L0 64V0z"/><path fill="#c8102e" d="m424 281 216 159v40L369 281zm-184 20 6 35L54 480H0zM640 0v3L391 191l2-44L590 0zM0 0l239 176h-60L0 42z"/><path fill="#fff" d="M241 0v480h160V0zM0 160v160h640V160z"/><path fill="#c8102e" d="M0 193v96h640v-96zM273 0v480h96V0z"/></svg>
    </span>
  )}
</nav>

<style>
  .lang-picker {
    position: fixed;
    top: 20px;
    right: 60px;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .lang-flag {
    display: block;
    width: 22px;
    height: 16px;
    border-radius: 2px;
    overflow: hidden;
    transition: opacity 0.2s ease;
    opacity: 0.35;
    text-decoration: none;
  }

  .lang-flag:hover {
    opacity: 0.8;
  }

  .lang-flag.active {
    opacity: 1;
  }

  .lang-flag svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 600px) {
    .lang-picker {
      top: 12px;
      right: 32px;
    }
  }

  @media print {
    .lang-picker {
      display: none !important;
    }
  }
</style>
