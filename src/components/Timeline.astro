---
import { useTranslations } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";
import { getTimelineJobs } from "../i18n/cv";

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const jobs = getTimelineJobs(lang);
---

<div class="section-inner jobs-section">
    <div class="section-label reveal">{t("timeline.label")}</div>
    <h2 class="section-heading reveal reveal-delay-1">
        {t("timeline.heading.before")}<span class="highlight">{t("timeline.heading.highlight")}</span>{t("timeline.heading.after")}
    </h2>

    <div class="job-cards reveal reveal-delay-2">
        {jobs.map((job, i) => (
            <div
                class="job-card"
                style={`--job-color: ${job.color}; --i: ${i};`}
            >
                <div class="job-header">
                    <span class="job-role">{job.role}</span>
                    <span class="job-date">{job.date}</span>
                </div>
                <span class="job-company">{job.company}</span>
                {job.bullets.length > 0 && (
                    <ul class="job-bullets">
                        {job.bullets.slice(0, 2).map((b) => (
                            <li set:html={b} />
                        ))}
                    </ul>
                )}
                {job.techStack.length > 0 && (
                    <div class="job-tech">{job.techStack.join(" · ")}</div>
                )}
            </div>
        ))}
    </div>
</div>

<!-- Print fallback -->
<div class="timeline-print-fallback" style="display:none">
    <div class="section-label">{t("timeline.label")}</div>
    <h2 class="section-heading">{t("timeline.heading.before")}<span class="highlight">{t("timeline.heading.highlight")}</span>{t("timeline.heading.after")}</h2>
    <div class="timeline-print-list">
        {jobs.map((job) => (
            <div class="timeline-print-item">
                <div class="timeline-print-dot" style={`background: ${job.color};`} />
                <div class="timeline-print-date">{job.date}</div>
                <div class="timeline-print-role">{job.role}</div>
                <div class="timeline-print-company">{job.company}</div>
                {job.techStack.length > 0 && (
                    <div class="timeline-print-tech">{job.techStack.join(" · ")}</div>
                )}
            </div>
        ))}
    </div>
</div>

<style>
    .jobs-section {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 100%;
        height: 100%;
    }

    .job-cards {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: clamp(8px, 1.2vh, 14px);
        width: 100%;
        max-width: 620px;
        overflow-y: auto;
        padding: 4px 0 24px;
    }

    .job-card {
        border-left: 3px solid var(--job-color);
        padding: 10px 14px;
        background: var(--bg-card);
        border-radius: 0 6px 6px 0;
        opacity: 0;
        animation: cardIn 0.4s ease forwards;
        animation-delay: calc(var(--i) * 80ms);
    }

    .job-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 12px;
    }

    .job-role {
        font-size: clamp(14px, 1.8vw, 17px);
        font-weight: 700;
        color: var(--text);
        line-height: 1.3;
    }

    .job-date {
        font-family: var(--mono);
        font-size: clamp(10px, 1.2vw, 12px);
        color: var(--text-muted);
        white-space: nowrap;
        flex-shrink: 0;
    }

    .job-company {
        display: block;
        font-family: var(--mono);
        font-size: clamp(11px, 1.3vw, 13px);
        color: var(--text-dim);
        line-height: 1.4;
        margin-top: 1px;
    }

    .job-bullets {
        list-style: none;
        margin-top: 6px;
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .job-bullets li {
        font-size: clamp(11px, 1.2vw, 13px);
        color: var(--text-dim);
        line-height: 1.4;
        padding-left: 12px;
        position: relative;
    }

    .job-bullets li::before {
        content: '·';
        position: absolute;
        left: 0;
        color: var(--text-muted);
        font-weight: 700;
    }

    .job-bullets li :global(strong) {
        color: var(--text);
        font-weight: 600;
    }

    .job-tech {
        font-family: var(--mono);
        font-size: clamp(9px, 1vw, 11px);
        color: var(--text-muted);
        margin-top: 6px;
        line-height: 1.4;
    }

    @keyframes cardIn {
        from {
            opacity: 0;
            transform: translateY(12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
        .job-card {
            opacity: 1;
            animation: none;
        }
    }

    /* Mobile */
    @media (max-width: 600px) {
        .job-cards {
            max-width: 100%;
        }
        .job-card {
            padding: 8px 10px;
        }
    }

    /* Print */
    .timeline-print-fallback { display: none; }
    @media print {
        .jobs-section { display: none !important; }
        .timeline-print-fallback { display: block !important; }
        .timeline-print-list { position: relative; padding-left: 24px; }
        .timeline-print-list::before {
            content: ''; position: absolute; left: 5px; top: 0; bottom: 0;
            width: 2px; background: var(--border);
        }
        .timeline-print-item { position: relative; margin-bottom: 5px; padding-left: 14px; }
        .timeline-print-item::before {
            content: ''; position: absolute; left: -22px; top: 5px;
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--purple); border: 3px solid var(--bg);
        }
        .timeline-print-dot { display: none; }
        .timeline-print-item:first-child::before { box-shadow: 0 0 12px var(--purple); }
        .timeline-print-date { font-family: var(--mono); font-size: 8px; color: var(--purple); }
        .timeline-print-role { font-size: 10px; font-weight: 700; line-height: 1.2; }
        .timeline-print-company { font-size: 8px; color: var(--text-dim); }
        .timeline-print-tech { font-family: var(--mono); font-size: 7px; color: var(--text-muted); margin-top: 1px; }
    }
</style>
