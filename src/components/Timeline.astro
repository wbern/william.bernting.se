---
import { useTranslations } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";
import { getJobs } from "../i18n/jobs";

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const jobs = getJobs(lang);
// Reverse: index 0 = bottom (HPE), 7 = top (Akka)
const blocks = [...jobs].reverse();
---

<div class="section-inner tower-section">
    <div class="section-label reveal">{t("timeline.label")}</div>
    <h2 class="section-heading reveal reveal-delay-1">
        {t("timeline.heading.before")}<span class="highlight">{t("timeline.heading.highlight")}</span>{t("timeline.heading.after")}
    </h2>

    <div class="tower-stage reveal reveal-delay-2" data-testid="tower-stage">
        <div class="tower-container">
            {blocks.map((block, i) => (
                <div
                    class="tower-block"
                    data-block-index={i}
                    style={`--block-color: ${block.color}; --block-w: ${block.w};`}
                >
                    <span class="block-date">{block.date}</span>
                    <div class="tower-label">
                        <span class="label-role">{block.role}</span>
                        <span class="label-company">{block.company}</span>
                    </div>
                </div>
            ))}
        </div>
        <div class="tower-floor"></div>
    </div>
</div>

<!-- Print fallback -->
<div class="timeline-print-fallback" style="display:none">
    <div class="section-label">{t("timeline.label")}</div>
    <h2 class="section-heading">{t("timeline.heading.before")}<span class="highlight">{t("timeline.heading.highlight")}</span>{t("timeline.heading.after")}</h2>
    <div class="timeline-print-list">
        {jobs.map((job) => (
            <div class="timeline-print-item">
                <div class="timeline-print-date">{job.date}</div>
                <div class="timeline-print-role">{job.role}</div>
                <div class="timeline-print-company">{job.company}</div>
            </div>
        ))}
    </div>
</div>

<style>
    .tower-section {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 100%;
        height: 100%;
    }

    .tower-stage {
        position: relative;
        width: 100%;
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .tower-container {
        flex: 1;
        display: flex;
        flex-direction: column-reverse;
        align-items: flex-start;
        justify-content: center;
        gap: clamp(4px, 0.8vh, 8px);
        padding-bottom: 4px;
    }

    /* ===== BLOCK ===== */
    .tower-block {
        flex: 1;
        min-height: 28px;
        max-height: 80px;
        width: calc(var(--block-w) * 0.55%);
        border-radius: 4px;
        position: relative;
        opacity: 0;
        transform: translateY(-300px);
        will-change: transform;
        transform-origin: center bottom;
        background:
            linear-gradient(135deg,
                rgba(255,255,255,0.2) 0%,
                rgba(255,255,255,0.06) 35%,
                transparent 55%),
            var(--block-color);
        box-shadow:
            inset 0 1px 0 rgba(255,255,255,0.3),
            inset 0 -2px 0 rgba(0,0,0,0.2),
            0 2px 6px rgba(0,0,0,0.4);
    }

    /* Grid texture */
    .tower-block::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(90deg, rgba(0,0,0,0.07) 1px, transparent 1px),
            linear-gradient(0deg, rgba(0,0,0,0.07) 1px, transparent 1px);
        background-size: 15px 15px;
        border-radius: inherit;
        pointer-events: none;
    }

    /* ===== DATE (inside block) ===== */
    .block-date {
        position: absolute;
        right: 8px;
        top: 50%;
        transform: translateY(-50%);
        font-family: var(--mono);
        font-size: clamp(9px, 1.2vh, 13px);
        font-weight: 600;
        color: rgba(0, 0, 0, 0.5);
        pointer-events: none;
        z-index: 1;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .tower-block.settled {
        cursor: grab;
    }

    .tower-block.settled .block-date,
    .tower-block.freed .block-date {
        opacity: 1;
    }

    /* ===== LABEL (right of block) ===== */
    .tower-label {
        position: absolute;
        left: calc(100% + 14px);
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .tower-block.settled .tower-label,
    .tower-block.freed .tower-label {
        opacity: 1;
    }

    .label-role {
        font-size: clamp(13px, 1.8vh, 20px);
        font-weight: 700;
        color: var(--text);
        line-height: 1.2;
    }

    .label-company {
        font-size: clamp(10px, 1.3vh, 15px);
        color: var(--text-dim);
        line-height: 1.3;
        font-family: var(--mono);
    }

    /* ===== FLOOR ===== */
    .tower-floor {
        width: 55%;
        height: 3px;
        background: var(--border);
        border-radius: 2px;
        flex-shrink: 0;
    }

    /* ===== MOBILE ===== */
    @media (max-width: 600px) {
        .tower-label {
            left: calc(100% + 10px);
        }
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
        .tower-block { opacity: 1; transform: none; }
        .tower-label { opacity: 1; transition: none; }
    }

    /* Print */
    .timeline-print-fallback { display: none; }
    @media print {
        .tower-section { display: none !important; }
        .timeline-print-fallback { display: block !important; }
        .timeline-print-list { position: relative; padding-left: 24px; }
        .timeline-print-list::before {
            content: ''; position: absolute; left: 5px; top: 0; bottom: 0;
            width: 2px; background: var(--border);
        }
        .timeline-print-item { position: relative; margin-bottom: 5px; padding-left: 14px; }
        .timeline-print-item::before {
            content: ''; position: absolute; left: -22px; top: 5px;
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--purple); border: 3px solid var(--bg);
        }
        .timeline-print-item:first-child::before { box-shadow: 0 0 12px var(--purple); }
        .timeline-print-date { font-family: var(--mono); font-size: 8px; color: var(--purple); }
        .timeline-print-role { font-size: 10px; font-weight: 700; line-height: 1.2; }
        .timeline-print-company { font-size: 8px; color: var(--text-dim); }
    }
</style>

<script>
    (function () {
        /*
         * Spring-damper physics: F = -K * displacement - B * velocity
         * Damping ratio ζ = B / (2√K). ζ < 1 = underdamped wobble.
         *
         * All transforms are offsets from the block's natural flex position.
         * Y=0 is "at rest in stack". Y<0 is "above rest".
         */

        const GRAVITY    = 1800;   // px/s² — slower, dramatic fall
        const DT_CAP     = 0.05;
        const STAGGER_MS = 130;    // gap between block drops
        const START_Y    = -300;   // initial offset above rest

        // Y spring (bounce on landing)
        const Y_K = 450;  const Y_B = 30;   // ζ ≈ 0.71

        // X spring (lateral wobble)
        const X_K = 380;  const X_B = 24;   // ζ ≈ 0.62

        // Rotation spring
        const R_K = 320;  const R_B = 21;   // ζ ≈ 0.59

        const SETTLE_VEL = 1.0;
        const SETTLE_POS = 0.5;

        const stage = document.querySelector<HTMLElement>('.tower-stage');
        if (!stage) return;
        const els = Array.from(stage.querySelectorAll<HTMLElement>('.tower-block'));
        if (!els.length) return;

        // Per-block personality derived from count — scales with any number of jobs
        const N = els.length;
        const W      = Array.from({length: N}, (_, i) => +((i + 1) / N).toFixed(2));
        const REST_X = Array.from({length: N}, (_, i) =>
            i === 0 ? 0 : +((i % 2 ? 1 : -1) * (0.5 + 0.3 * Math.sin(i * 1.7))).toFixed(1));
        const REST_R = Array.from({length: N}, (_, i) =>
            i === 0 ? 0 : +((i % 2 ? -1 : 1) * (0.15 + 0.1 * Math.sin(i * 2.3))).toFixed(2));
        const HIT_R  = Array.from({length: N}, (_, i) =>
            i === 0 ? 0 : Math.round((i % 2 ? 1 : -1) * (20 + i * 4)));
        const HIT_X  = Array.from({length: N}, (_, i) =>
            i === 0 ? 0 : Math.round((i % 2 ? 1 : -1) * (10 + i * 2)));

        let animId: number | null = null;
        let running = false;

        interface S {
            el: HTMLElement; i: number;
            y: number; vy: number;
            x: number; vx: number;
            r: number; vr: number;
            phase: 'wait' | 'fall' | 'settle' | 'done' | 'freed';
            t0: number;
        }
        const st: S[] = [];

        function init() {
            st.length = 0;
            els.forEach((el, i) => {
                el.style.opacity = '0';
                el.style.transform = `translateY(${START_Y}px)`;
                el.classList.remove('settled');
                st.push({
                    el, i,
                    y: START_Y, vy: 0,
                    x: 0, vx: 0,
                    r: 0, vr: 0,
                    phase: 'wait',
                    t0: i * STAGGER_MS,
                });
            });
        }

        function tx(s: S) {
            s.el.style.transform =
                `translateY(${s.y}px) translateX(${s.x}px) rotate(${s.r}deg)`;
        }

        function run() {
            if (running) return;
            running = true;
            init();
            const t0 = performance.now();
            let prev = t0;

            function tick(now: number) {
                const dt = Math.min((now - prev) / 1000, DT_CAP);
                prev = now;
                const elapsed = now - t0;
                let allDone = true;

                for (const s of st) {
                    if (s.phase === 'done' || s.phase === 'freed') continue;
                    allDone = false;

                    if (s.phase === 'wait') {
                        if (elapsed >= s.t0) {
                            s.phase = 'fall';
                            s.el.style.opacity = '1';
                        }
                        continue;
                    }

                    if (s.phase === 'fall') {
                        s.vy += GRAVITY * dt;
                        s.y += s.vy * dt;
                        // Gentle tumble
                        s.r = Math.sin(elapsed * 0.005 + s.i * 1.7) * 3 * W[s.i];

                        if (s.y >= 0) {
                            s.y = 0;
                            s.phase = 'settle';
                            s.vy = -s.vy * 0.1;
                            s.vx = HIT_X[s.i] * W[s.i];
                            s.vr = HIT_R[s.i] * W[s.i];
                            s.r = 0;
                            s.x = 0;
                        }
                        tx(s);
                        continue;
                    }

                    if (s.phase === 'settle') {
                        // Y spring
                        s.vy += (-Y_K * s.y - Y_B * s.vy) * dt;
                        s.y  += s.vy * dt;
                        // X spring
                        const xr = REST_X[s.i];
                        s.vx += (-X_K * (s.x - xr) - X_B * s.vx) * dt;
                        s.x  += s.vx * dt;
                        // Rotation spring
                        const rr = REST_R[s.i];
                        s.vr += (-R_K * (s.r - rr) - R_B * s.vr) * dt;
                        s.r  += s.vr * dt;

                        if (Math.abs(s.vy) < SETTLE_VEL &&
                            Math.abs(s.y) < SETTLE_POS &&
                            Math.abs(s.vx) < SETTLE_VEL &&
                            Math.abs(s.vr) < SETTLE_VEL) {
                            s.phase = 'done';
                            s.y = 0; s.x = xr; s.r = rr;
                            s.el.classList.add('settled');
                        }
                        tx(s);
                    }
                }

                if (allDone) { animId = null; running = false; return; }
                animId = requestAnimationFrame(tick);
            }
            animId = requestAnimationFrame(tick);
        }

        function showFinal() {
            els.forEach((el, i) => {
                el.style.opacity = '1';
                el.style.transform =
                    `translateY(0) translateX(${REST_X[i]}px) rotate(${REST_R[i]}deg)`;
                el.classList.add('settled');
            });
        }

        function reset() {
            if (animId !== null) { cancelAnimationFrame(animId); animId = null; }
            running = false;
            dragState = null;
            els.forEach(el => {
                el.style.opacity = '0';
                el.style.transform = `translateY(${START_Y}px)`;
                el.style.position = '';
                el.style.left = '';
                el.style.top = '';
                el.style.flex = '';
                el.style.width = '';
                el.style.height = '';
                el.classList.remove('settled', 'freed');
            });
        }

        // ─── Drag-and-throw ───
        let dragState: { s: S; offX: number; offY: number; prevX: number; prevY: number; vx: number; vy: number } | null = null;

        /** Free ALL blocks — snapshot positions first, then switch to absolute.
         *  This avoids cascading flex re-layout as each block leaves the flow. */
        function freeAllBlocks() {
            const stageRect = stage.getBoundingClientRect();
            const toFree: { s: S; rect: DOMRect }[] = [];

            // 1) Snapshot every block's current visual rect while flex is intact
            for (const s of st) {
                if (s.phase === 'freed') continue;
                toFree.push({ s, rect: s.el.getBoundingClientRect() });
            }

            // 2) Apply absolute positioning using the snapshotted rects
            for (const { s, rect } of toFree) {
                s.phase = 'freed';
                s.el.classList.remove('settled');
                s.el.classList.add('freed');

                s.x = rect.left - stageRect.left;
                s.y = rect.top - stageRect.top;
                s.vx = 0; s.vy = 0; s.vr = 0;

                s.el.style.width = rect.width + 'px';
                s.el.style.height = rect.height + 'px';
                s.el.style.position = 'absolute';
                s.el.style.left = '0';
                s.el.style.top = '0';
                s.el.style.flex = 'none';

                tx(s);
            }
        }

        els.forEach((blockEl, blockIdx) => {
            blockEl.addEventListener('pointerdown', (e) => {
                if (!blockEl.classList.contains('settled') && !blockEl.classList.contains('freed')) return;
                const s = st[blockIdx];
                if (!s) return;

                e.stopPropagation();
                e.preventDefault();
                blockEl.setPointerCapture(e.pointerId);

            // Free all blocks on first interaction
            freeAllBlocks();

            const rect = blockEl.getBoundingClientRect();
            const stageRect = stage.getBoundingClientRect();

            dragState = {
                s,
                offX: e.clientX - rect.left,
                offY: e.clientY - rect.top,
                prevX: e.clientX,
                prevY: e.clientY,
                vx: 0, vy: 0,
            };

            tx(s);
            });
        });

        window.addEventListener('pointermove', (e) => {
            if (!dragState) return;
            const { s } = dragState;
            const stageRect = stage.getBoundingClientRect();

            dragState.vx = (e.clientX - dragState.prevX) * 60;
            dragState.vy = (e.clientY - dragState.prevY) * 60;
            dragState.prevX = e.clientX;
            dragState.prevY = e.clientY;

            s.x = e.clientX - stageRect.left - dragState.offX;
            s.y = e.clientY - stageRect.top - dragState.offY;
            s.vx = 0; s.vy = 0;
            tx(s);
        });

        window.addEventListener('pointerup', () => {
            if (!dragState) return;
            const { s, vx, vy } = dragState;
            s.vx = vx;
            s.vy = vy;
            s.vr = (Math.random() - 0.5) * 3 * Math.min(1, Math.abs(vx) / 400);
            dragState = null;

            if (!running) startPhysicsLoop();
        });

        // Touch equivalents
        stage.addEventListener('touchstart', (e) => {
            if (e.touches.length !== 1) return;
            const touch = e.touches[0];
            const target = document.elementFromPoint(touch.clientX, touch.clientY)?.closest('.tower-block') as HTMLElement | null;
            if (!target || !target.classList.contains('settled')) return;
            const idx = els.indexOf(target);
            if (idx < 0) return;
            const s = st[idx];
            if (!s) return;

            e.stopPropagation();
            e.preventDefault();

            // Free all blocks on first interaction
            freeAllBlocks();

            const rect = target.getBoundingClientRect();
            const stageRect = stage.getBoundingClientRect();

            dragState = {
                s,
                offX: touch.clientX - rect.left,
                offY: touch.clientY - rect.top,
                prevX: touch.clientX,
                prevY: touch.clientY,
                vx: 0, vy: 0,
            };

            tx(s);
        }, { passive: false });

        stage.addEventListener('touchmove', (e) => {
            if (!dragState) return;
            e.preventDefault();
            e.stopPropagation();
            const touch = e.touches[0];
            const stageRect = stage.getBoundingClientRect();

            dragState.vx = (touch.clientX - dragState.prevX) * 60;
            dragState.vy = (touch.clientY - dragState.prevY) * 60;
            dragState.prevX = touch.clientX;
            dragState.prevY = touch.clientY;

            dragState.s.x = touch.clientX - stageRect.left - dragState.offX;
            dragState.s.y = touch.clientY - stageRect.top - dragState.offY;
            dragState.s.vx = 0; dragState.s.vy = 0;
            tx(dragState.s);
        }, { passive: false });

        stage.addEventListener('touchend', () => {
            if (!dragState) return;
            const { s, vx, vy } = dragState;
            s.vx = vx;
            s.vy = vy;
            s.vr = (Math.random() - 0.5) * 3 * Math.min(1, Math.abs(vx) / 400);
            dragState = null;
            if (!running) startPhysicsLoop();
        });

        // Physics loop for freed blocks (gravity, walls, floor, block-block collision)
        function startPhysicsLoop() {
            if (running) return;
            const freedBlocks = st.filter(s => s.phase === 'freed');
            if (!freedBlocks.length) return;
            running = true;
            let prev = performance.now();

            const FREED_GRAVITY = 600;
            const FREED_BOUNCE = 0.35;
            const FREED_FRICTION = 0.6;
            const FREED_AIR_DRAG = 0.997;
            const FREED_ROT_DRAG = 0.92;
            const FREED_ROT_SPRING = 6;
            const COL_GAP = 2;          // px margin between blocks
            const COL_ITERATIONS = 3;   // resolve overlaps iteratively

            function physTick(now: number) {
                const dt = Math.min((now - prev) / 1000, DT_CAP);
                prev = now;
                const stageW = stage.offsetWidth;
                const stageH = stage.offsetHeight;

                // Integrate velocity → position
                const active: S[] = [];
                for (const s of st) {
                    if (s.phase !== 'freed') continue;
                    active.push(s);
                    if (dragState?.s === s) continue; // being dragged

                    s.vy += FREED_GRAVITY * dt;
                    s.vx *= FREED_AIR_DRAG;
                    s.vy *= FREED_AIR_DRAG;
                    s.vr *= FREED_ROT_DRAG;
                    s.vr += -FREED_ROT_SPRING * s.r * dt;

                    s.x += s.vx * dt;
                    s.y += s.vy * dt;
                    s.r += s.vr * dt;
                }

                // Block-block AABB collision (multiple iterations to stabilise stacks)
                for (let iter = 0; iter < COL_ITERATIONS; iter++) {
                    for (let i = 0; i < active.length; i++) {
                        const a = active[i];
                        const aw = a.el.offsetWidth;
                        const ah = a.el.offsetHeight;
                        for (let j = i + 1; j < active.length; j++) {
                            const b = active[j];
                            const bw = b.el.offsetWidth;
                            const bh = b.el.offsetHeight;

                            const overlapX = (aw + bw) / 2 + COL_GAP - Math.abs((a.x + aw / 2) - (b.x + bw / 2));
                            const overlapY = (ah + bh) / 2 + COL_GAP - Math.abs((a.y + ah / 2) - (b.y + bh / 2));
                            if (overlapX <= 0 || overlapY <= 0) continue;

                            const aDragged = dragState?.s === a;
                            const bDragged = dragState?.s === b;

                            if (overlapY < overlapX) {
                                // Resolve vertically
                                const sign = (a.y + ah / 2) < (b.y + bh / 2) ? -1 : 1;
                                if (aDragged) {
                                    b.y += sign * overlapY;
                                } else if (bDragged) {
                                    a.y -= sign * overlapY;
                                } else {
                                    a.y -= sign * overlapY * 0.5;
                                    b.y += sign * overlapY * 0.5;
                                }
                                // Velocity exchange
                                if (!aDragged && !bDragged) {
                                    const avgVy = (a.vy + b.vy) * 0.5;
                                    a.vy = avgVy * FREED_BOUNCE;
                                    b.vy = avgVy * FREED_BOUNCE;
                                } else if (aDragged) {
                                    b.vy = -b.vy * FREED_BOUNCE + sign * 100;
                                } else {
                                    a.vy = -a.vy * FREED_BOUNCE - sign * 100;
                                }
                            } else {
                                // Resolve horizontally
                                const sign = (a.x + aw / 2) < (b.x + bw / 2) ? -1 : 1;
                                if (aDragged) {
                                    b.x += sign * overlapX;
                                } else if (bDragged) {
                                    a.x -= sign * overlapX;
                                } else {
                                    a.x -= sign * overlapX * 0.5;
                                    b.x += sign * overlapX * 0.5;
                                }
                                if (!aDragged && !bDragged) {
                                    const avgVx = (a.vx + b.vx) * 0.5;
                                    a.vx = avgVx * FREED_BOUNCE;
                                    b.vx = avgVx * FREED_BOUNCE;
                                } else if (aDragged) {
                                    b.vx = -b.vx * FREED_BOUNCE + sign * 100;
                                } else {
                                    a.vx = -a.vx * FREED_BOUNCE - sign * 100;
                                }
                            }
                            // Add spin on collision
                            if (!aDragged) a.vr += (Math.random() - 0.5) * 0.5;
                            if (!bDragged) b.vr += (Math.random() - 0.5) * 0.5;
                        }
                    }
                }

                // Wall / floor / ceiling clamp
                for (const s of active) {
                    if (dragState?.s === s) continue;
                    const w = s.el.offsetWidth;
                    const h = s.el.offsetHeight;

                    if (s.y + h > stageH) {
                        s.y = stageH - h;
                        s.vy = -s.vy * FREED_BOUNCE;
                        s.vx *= FREED_FRICTION;
                        if (Math.abs(s.vy) > 10) s.vr += (Math.random() - 0.5) * 1;
                    }
                    if (s.x < 0) { s.x = 0; s.vx = -s.vx * FREED_BOUNCE; }
                    if (s.x + w > stageW) { s.x = stageW - w; s.vx = -s.vx * FREED_BOUNCE; }
                    if (s.y < 0) { s.y = 0; s.vy = -s.vy * FREED_BOUNCE; }

                    tx(s);
                }

                if (active.length > 0) {
                    animId = requestAnimationFrame(physTick);
                } else {
                    animId = null;
                    running = false;
                }
            }
            animId = requestAnimationFrame(physTick);
        }

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            showFinal(); return;
        }

        const rev = stage.closest('.reveal') || stage;
        let resetTimer: ReturnType<typeof setTimeout> | null = null;

        const obs = new MutationObserver(() => {
            if (rev.classList.contains('visible')) {
                if (resetTimer) { clearTimeout(resetTimer); resetTimer = null; }
                if (!running) run();
            } else {
                // Delay reset so transient class flickers (e.g. click) don't restart
                resetTimer = setTimeout(() => { reset(); resetTimer = null; }, 200);
            }
        });
        obs.observe(rev, { attributes: true, attributeFilter: ['class'] });
        if (rev.classList.contains('visible')) run();
    })();
</script>
