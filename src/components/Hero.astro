---
import { useTranslations } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";
import { getTraitRows } from "../i18n/traits";
import MarqueeField from "./MarqueeField.astro";

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const rows = getTraitRows(lang);

const topRows = rows.slice(0, 2);
const bottomRows = rows.slice(2);

const greeting = t("hero.greeting");
const greetingLen = greeting.length;
---

<div class="hero-slide">
    <div class="hero-marquee-wrap hero-marquee-top">
        <MarqueeField rows={topRows} />
    </div>

    <div class="hero-center">
        <div
            class="hero-greeting"
            style={`--greeting-width: ${greetingLen}ch; animation: typewriter 1s steps(${greetingLen}) 0.5s forwards, blink 0.7s step-end infinite, greetingFade 0.8s ease 1.8s forwards;`}
        >{greeting}</div>
        <h1>William Bernting</h1>
    </div>

    <div class="hero-marquee-wrap hero-marquee-bottom">
        <MarqueeField rows={bottomRows} />
    </div>

    <div class="hero-contact-print" style="display: none;">
        <a href="mailto:william@bernting.se">william@bernting.se</a>
        <span>+46 706 67 60 47</span>
        <a href="https://www.linkedin.com/in/williambernting">LinkedIn</a>
        <a href="https://www.kendev.se/">kendev.se</a>
        <span>Gothenburg, Sweden</span>
    </div>
    <div class="hero-scroll-hint">{t("hero.scroll")}</div>
</div>

<style>
    .hero-slide {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        height: 100%;
        width: 100%;
        position: relative;
    }

    .hero-marquee-wrap {
        flex: 1;
        display: flex;
        align-items: center;
        width: 100vw;
        opacity: 0;
    }

    .hero-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 24px 0;
        flex-shrink: 0;
    }

    .hero-greeting {
        font-family: var(--mono);
        font-size: 18px;
        color: var(--text);
        margin-bottom: 20px;
        overflow: hidden;
        white-space: nowrap;
        border-right: 2px solid var(--text);
        width: 0;
    }

    @keyframes typewriter {
        to { width: var(--greeting-width); }
    }

    @keyframes blink {
        50% { border-color: transparent; }
    }

    @keyframes greetingFade {
        to {
            color: var(--text-muted);
            border-color: transparent;
        }
    }

    h1 {
        font-size: clamp(48px, 8vw, 96px);
        font-weight: 900;
        letter-spacing: -2px;
        line-height: 1;
        opacity: 0;
        animation: fadeUp 1s ease 1.8s forwards;
    }

    .hero-marquee-top {
        animation: fadeDown 1s ease 2.4s forwards;
    }

    .hero-marquee-bottom {
        animation: fadeUp 1s ease 2.4s forwards;
    }

    .hero-scroll-hint {
        position: absolute;
        bottom: 40px;
        font-family: var(--mono);
        font-size: 13px;
        color: var(--text-muted);
        opacity: 0;
        animation: fadeUp 1s ease 3.2s forwards, float 3s ease-in-out infinite 3.2s;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
    }

    @media print {
        .hero-slide {
            text-align: center;
            padding-bottom: 2px;
        }
        .hero-greeting {
            animation: none !important;
            width: auto !important;
            border: none;
            font-size: 10px;
            margin-bottom: 2px;
        }
        h1 {
            font-size: 24px;
            animation: none;
            opacity: 1;
            margin-bottom: 2px;
        }
        .hero-center { padding: 0; }
        .hero-marquee-wrap {
            display: none;
        }
        .hero-scroll-hint {
            display: none;
        }
    }
</style>
