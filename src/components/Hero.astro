---
import { useTranslations } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";
import { getTraitRows } from "../i18n/traits";
import MarqueeField from "./MarqueeField.astro";

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const rows = getTraitRows(lang);

const topRows = rows.slice(0, 2);
const bottomRows = rows.slice(2);
const allTraits = rows.flatMap((r) => r.items);

const greeting = t("hero.greeting");
const greetingLen = greeting.length;
---

<div class="hero-slide">
    <div class="hero-marquee-wrap hero-marquee-top">
        <MarqueeField rows={topRows} />
    </div>

    <div class="hero-center">
        <div
            class="hero-greeting"
            style={`--greeting-width: ${greetingLen}ch; animation: typewriter 1s steps(${greetingLen}) 0.5s forwards, blink 0.7s step-end infinite, greetingFade 0.8s ease 1.8s forwards;`}
        >{greeting}</div>
        <h1>William Bernting</h1>
        <div class="hero-contact">
            <a href="https://www.linkedin.com/in/williambernting" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="mailto:william@bernting.se">william@bernting.se</a>
            <a href="tel:+46706676047">+46 706 67 60 47</a>
        </div>
    </div>

    <div class="hero-marquee-wrap hero-marquee-bottom">
        <MarqueeField rows={bottomRows} />
    </div>

    <div class="hero-contact-print" style="display: none;">
        <a href="mailto:william@bernting.se">william@bernting.se</a>
        <span>+46 706 67 60 47</span>
        <a href="https://www.linkedin.com/in/williambernting">LinkedIn</a>
        <a href="https://www.kendev.se/">kendev.se</a>
        <span>Gothenburg, Sweden</span>
    </div>
    <div class="hero-scroll-hint">{t("hero.scroll")}</div>

    <div class="sr-only traits-keywords">
        {allTraits.join(", ")}
    </div>
</div>

<style>
    .hero-slide {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        height: 100%;
        width: 100%;
        position: relative;
    }

    .hero-marquee-wrap {
        flex: 1;
        display: flex;
        align-items: center;
        width: 100vw;
        opacity: 0;
    }

    .hero-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 24px 0;
        flex-shrink: 0;
    }

    .hero-greeting {
        font-family: var(--mono);
        font-size: 18px;
        color: var(--text);
        margin-bottom: 20px;
        overflow: hidden;
        white-space: nowrap;
        border-right: 2px solid var(--text);
        width: 0;
    }

    @keyframes typewriter {
        to { width: var(--greeting-width); }
    }

    @keyframes blink {
        50% { border-color: transparent; }
    }

    @keyframes greetingFade {
        to {
            color: var(--text-muted);
            border-color: transparent;
        }
    }

    h1 {
        font-size: clamp(48px, 8vw, 96px);
        font-weight: 900;
        letter-spacing: -2px;
        line-height: 1;
        opacity: 0;
        animation: fadeUp 1s ease 1.8s forwards;
    }

    .hero-contact {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 16px;
        font-family: var(--mono);
        font-size: 12px;
        opacity: 0;
        animation: fadeUp 1s ease 2.8s forwards;
    }

    .hero-contact a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.3s ease;
        display: flex;
        align-items: center;
    }

    .hero-contact a:hover {
        color: var(--text-dim);
    }

    .hero-contact svg {
        width: 14px;
        height: 14px;
    }

    .hero-marquee-top {
        animation: fadeDown 1s ease 2.4s forwards;
    }

    .hero-marquee-bottom {
        animation: fadeUp 1s ease 2.4s forwards;
    }

    .hero-scroll-hint {
        position: absolute;
        bottom: 40px;
        font-family: var(--mono);
        font-size: 13px;
        color: var(--text-muted);
        opacity: 0;
        animation: fadeUp 1s ease 3.2s forwards, float 3s ease-in-out infinite 3.2s;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    @media print {
        .hero-slide {
            text-align: center;
            padding-bottom: 2px;
        }
        .hero-greeting {
            animation: none !important;
            width: auto !important;
            border: none;
            font-size: 10px;
            margin-bottom: 2px;
        }
        h1 {
            font-size: 24px;
            animation: none;
            opacity: 1;
            margin-bottom: 2px;
        }
        .hero-center { padding: 0; }
        .hero-marquee-wrap {
            display: none;
        }
        .hero-scroll-hint {
            display: none;
        }
        .hero-contact {
            display: none;
        }
        .sr-only.traits-keywords {
            position: static;
            width: auto;
            height: auto;
            clip: unset;
            overflow: visible;
            white-space: normal;
            font-size: 9px;
            color: var(--text-dim);
            margin-top: 4px;
        }
    }
</style>
