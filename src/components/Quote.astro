---
import { useTranslations } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
---

<div class="section-inner">
    <div class="quote-section reveal">
        <div class="quote-text">
            {t("quote.text")}
        </div>
        <div class="quote-author">&mdash; {t("quote.author")}</div>
    </div>

    <div class="contact-bar reveal reveal-delay-2">
        <a class="contact-link" href="mailto:william@bernting.se">william@bernting.se</a>
        <a class="contact-link" href="tel:+46706676047">+46 706 67 60 47</a>
        <a class="contact-link" href="https://www.linkedin.com/in/williambernting">LinkedIn</a>
        <a class="contact-link" href="https://www.kendev.se/">kendev.se</a>
        <span class="contact-link">Gothenburg, Sweden</span>
    </div>
</div>

<style>
    .quote-section {
        text-align: center;
        padding: 40px 0;
    }

    .quote-text {
        font-size: clamp(20px, 3vw, 32px);
        font-weight: 300;
        font-style: italic;
        color: var(--text);
        max-width: 700px;
        margin: 0 auto 16px;
        line-height: 1.5;
    }

    .quote-author {
        font-family: var(--mono);
        font-size: 14px;
        color: var(--text-muted);
    }

    .contact-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
        margin-top: 40px;
    }

    .contact-link {
        font-family: var(--mono);
        font-size: 14px;
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.2s;
    }

    .contact-link:hover {
        color: var(--purple);
    }
</style>
