---
import { useTranslations } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";
import { getProjects, getProjectSlugs } from "../i18n/projects";
import { PROJECT_ILLUSTRATIONS } from "./projectIllustrations";
import { blurPlaceholder } from "../utils/blur-placeholder";

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const projects = getProjects(lang);
const slugs = getProjectSlugs();

// Generate blur placeholders for every photo illustration at build time.
// Source list comes from PROJECT_ILLUSTRATIONS so it stays in sync automatically.
const blurMap: Record<string, { dataUrl: string; width: number; height: number }> = {};
for (const illustration of Object.values(PROJECT_ILLUSTRATIONS)) {
    if (illustration?.kind === "photo") {
        const filename = illustration.src.replace(/^\//, "");
        blurMap[illustration.src] = await blurPlaceholder(filename);
    }
}
---

<div class="section-inner roller-section" data-testid="projects-section">
    <!-- ===== VIEW 1: Roller ===== -->
    <div class="roller-view" data-testid="roller-view">
        <div class="section-label">{t("projects.label")}</div>
        <h2 class="section-heading">
            {t("projects.heading.before")}<span class="highlight">{t("projects.heading.highlight")}</span>{t("projects.heading.after")}
        </h2>

        <div class="roller-wrapper">
            <button class="roller-arrow" data-testid="roller-arrow-up" aria-label={t("projects.aria.prev")}>&#x25B2;</button>

            <div class="roller-viewport" data-testid="roller" data-keen-slider-clickable role="listbox" aria-label={t("projects.aria.list")}>
                <div id="roller-track" class="roller-track" aria-live="polite">
                    <!-- Slides populated by script -->
                </div>
                <!-- Centre-slot highlight overlay -->
                <div class="roller-highlight"></div>
            </div>

            <button class="roller-arrow" data-testid="roller-arrow-down" aria-label={t("projects.aria.next")}>&#x25BC;</button>
        </div>

        <div class="roller-actions">
            <button class="action-button action-button--spin" data-testid="spin-button">
                <svg class="spin-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M 19.5 12 A 7.5 7.5 0 1 0 15 18.9" />
                    <polyline points="19.5,8 19.5,12 15.5,12" />
                </svg>
            </button>
            <!-- Hidden but functional for test automation -->
            <button class="action-button action-button--open sr-only" data-testid="open-button">
                {t("projects.open")} &#x2192;
            </button>
        </div>
    </div>

    <!-- ===== VIEW 2: Detail ===== -->
    <div class="detail-view" data-testid="detail-view">
        <button class="back-button" data-testid="back-button" aria-label={t("projects.aria.back")} data-label={t("projects.back")}>
            <span class="back-arrow">&#x2190;</span> {t("projects.back")}
        </button>
        <div class="detail-card" data-testid="detail-card">
            <!-- Detail content injected by script -->
        </div>
    </div>
</div>

<!-- Print fallback (server-rendered) -->
<div class="section-inner projects-print-fallback">
    <div class="section-label">{t("projects.label")}</div>
    <h2 class="section-heading">{t("projects.heading.before")}<span class="highlight">{t("projects.heading.highlight")}</span>{t("projects.heading.after")}</h2>
    <div class="projects-grid">
        {projects.map((p) => (
            <div class="project-card">
                <div class="project-tag">{p.tag}</div>
                <h3>{p.title}</h3>
                <p>{p.description}</p>
            </div>
        ))}
    </div>
</div>

<!-- Inject translated project data for client JS -->
<script type="application/json" id="projects-i18n-data" set:html={JSON.stringify(projects)} />
<script type="application/json" id="projects-slugs-data" set:html={JSON.stringify(slugs)} />
<script type="application/json" id="projects-blur-data" set:html={JSON.stringify(blurMap)} />
<script type="application/json" id="projects-illustrations-data" set:html={JSON.stringify(PROJECT_ILLUSTRATIONS)} />

<script>
    const PROJECTS: { tag: string; title: string; description: string }[] =
        JSON.parse(document.getElementById("projects-i18n-data")!.textContent!);

    /* ── Deep-link slug map (English titles → index) ── */
    const PROJECT_SLUGS: string[] =
        JSON.parse(document.getElementById("projects-slugs-data")!.textContent!);
    const slugToIndex: Record<string, number> = {};
    PROJECT_SLUGS.forEach((slug, i) => { slugToIndex[slug] = i; });

    /* ── Blur placeholders for photo dioramas ── */
    const BLUR_DATA: Record<string, { dataUrl: string; width: number; height: number }> =
        JSON.parse(document.getElementById("projects-blur-data")!.textContent!);

    /* ── Illustrations (per-slug discriminated union, validated at compile time
       in projectIllustrations.ts via Record<ProjectSlug, Illustration | null>).
       Slug-keyed and exhaustive: missing or stale entries break the build. ── */
    type Illustration =
        | { kind: "svg"; markup: string }
        | { kind: "photo"; src: string; alt: string };
    const PROJECT_ILLUSTRATIONS: Record<string, Illustration | null> =
        JSON.parse(document.getElementById("projects-illustrations-data")!.textContent!);

    /** Build a photo diorama with blur-up placeholder. */
    function photoDiorama(src: string, alt: string): string {
        const blur = BLUR_DATA[src];
        if (!blur) {
            return `<div class="diorama diorama--photo"><img src="${src}" alt="${alt}" style="display:block;width:100%;height:auto;" /></div>`;
        }
        return `<div class="diorama diorama--photo">
            <div class="diorama-blur" style="background-image:url(${blur.dataUrl})">
                <img src="${src}" alt="${alt}" width="${blur.width}" height="${blur.height}" onload="this.classList.add('loaded')" />
            </div>
        </div>`;
    }

    /** Render the illustration for a given project slug, branching by kind. */
    function renderIllustration(slug: string): string {
        const il = PROJECT_ILLUSTRATIONS[slug];
        if (!il) return "";
        if (il.kind === "svg") return il.markup;
        return photoDiorama(il.src, il.alt);
    }

    const N = PROJECTS.length;

    let scrollPos = 0;       // continuous fractional scroll position
    let currentIdx = 0;      // integer index of selected item (set when settled)
    let targetIdx = 0;       // intended destination for manual nav
    let isSpinning = false;
    let isDetailView = false;
    let spinAnimId: number | null = null;
    let navAnimId: number | null = null;

    const section = document.querySelector("[data-testid='projects-section']") as HTMLElement;
    const detailCard = document.querySelector("[data-testid='detail-card']") as HTMLElement;
    const spinBtn = document.querySelector("[data-testid='spin-button']") as HTMLElement;
    const openBtn = document.querySelector("[data-testid='open-button']") as HTMLElement;
    const arrowUp = document.querySelector("[data-testid='roller-arrow-up']") as HTMLElement;
    const arrowDown = document.querySelector("[data-testid='roller-arrow-down']") as HTMLElement;
    const backBtn = document.querySelector("[data-testid='back-button']") as HTMLElement;
    const track = document.getElementById("roller-track") as HTMLElement;
    const viewport = document.querySelector("[data-testid='roller']") as HTMLElement;

    // Match the CSS media query for --slide-h: 76px on desktop, 60px on mobile
    const SLIDE_HEIGHT = window.matchMedia("(min-width: 901px)").matches ? 76 : 60;
    const CENTER_OFFSET = window.matchMedia("(min-height: 600px)").matches ? 1.5 : 1;

    function tagKey(tag: string): string {
        const t = tag.toLowerCase();
        if (t === "ai-agent" || t === "ai agent" || t === "ai / rag") return "ai";
        if (t === "infrastruktur" || t === "infrastructure") return "infra";
        if (t.includes("legacy") || t === "modernisering" || t === "modernization") return "legacy";
        if (t === "open source") return "open-source";
        if (t === "undervisning" || t === "teaching") return "teaching";
        if (t === "företag" || t === "business" || t === "ledarskap" || t === "leadership" || t === "dataanalys" || t === "data analysis") return "business";
        if (t === "meta") return "meta";
        return "creative"; // Personal Project, Game, 3D Visualization, fallback
    }

    // Build slide elements
    PROJECTS.forEach((p, i) => {
        const slide = document.createElement("div");
        slide.className = "roller-slide";
        slide.setAttribute("role", "option");
        slide.dataset.index = String(i);
        const key = tagKey(p.tag);
        slide.innerHTML = `<span class="roller-slide__tag" data-key="${key}">${p.tag}</span><span class="roller-slide__title">${p.title}</span>`;
        track.appendChild(slide);
    });

    const slides = Array.from(track.querySelectorAll(".roller-slide")) as HTMLElement[];

    function mod(n: number, m: number): number {
        return ((n % m) + m) % m;
    }

    // ── Rendering (continuous) ────────────────────────────
    // scrollPos is a fractional number. Each integer = one slide.
    // Slides are positioned via translateY based on their distance from scrollPos.

    function render() {
        const isSettled = Math.abs(scrollPos - Math.round(scrollPos)) < 0.01;
        const centerIdx = mod(Math.round(scrollPos), N);

        slides.forEach((el, i) => {
            // Shortest wrapped distance from this slide to the current scroll position
            let diff = i - scrollPos;
            diff -= N * Math.round(diff / N);

            const absDiff = Math.abs(diff);

            if (absDiff > 2.5) {
                el.style.transform = "";
                el.style.opacity = "0";
                el.style.pointerEvents = "none";
                el.classList.remove("roller-slide--selected", "roller-slide--near", "roller-slide--far");
                el.setAttribute("aria-selected", "false");
                delete el.dataset.testid;
                return;
            }

            // Position: centre slot sits at CENTER_OFFSET × SLIDE_HEIGHT from top of viewport
            const y = (diff + CENTER_OFFSET) * SLIDE_HEIGHT;
            el.style.transform = `translateY(${y}px)`;
            el.style.pointerEvents = "auto";

            // Smooth opacity falloff based on distance from centre
            el.style.opacity = String(Math.max(0, 1 - absDiff * 0.25));

            // State classes (only assign roller-selected when fully settled)
            el.classList.remove("roller-slide--selected", "roller-slide--near", "roller-slide--far");
            delete el.dataset.testid;

            if (isSettled && i === centerIdx) {
                el.classList.add("roller-slide--selected");
                el.dataset.testid = "roller-selected";
                el.setAttribute("aria-selected", "true");
            } else {
                el.setAttribute("aria-selected", "false");
                if (absDiff < 1.5) {
                    el.classList.add("roller-slide--near");
                } else {
                    el.classList.add("roller-slide--far");
                }
            }
        });
    }

    // ── Smooth navigation animation ──────────────────────

    function animateTo(dest: number, duration = 300) {
        if (navAnimId) { cancelAnimationFrame(navAnimId); navAnimId = null; }

        const target = mod(dest, N);
        const start = scrollPos;
        const currentNorm = mod(scrollPos, N);

        // Shortest path considering wrapping
        let diff = target - currentNorm;
        if (diff > N / 2) diff -= N;
        if (diff < -N / 2) diff += N;

        if (Math.abs(diff) < 0.01) {
            scrollPos = target;
            currentIdx = target;
            render();
            return;
        }

        const startTime = performance.now();

        function animate(now: number) {
            const t = Math.min((now - startTime) / duration, 1);
            const eased = 1 - Math.pow(1 - t, 2); // quadratic ease-out
            scrollPos = start + eased * diff;
            render();

            if (t < 1) {
                navAnimId = requestAnimationFrame(animate);
            } else {
                scrollPos = target;
                currentIdx = target;
                navAnimId = null;
                render();
            }
        }

        navAnimId = requestAnimationFrame(animate);
    }

    function next() {
        if (isSpinning || isDetailView) return;
        targetIdx = mod(targetIdx + 1, N);
        animateTo(targetIdx);
    }

    function prev() {
        if (isSpinning || isDetailView) return;
        targetIdx = mod(targetIdx - 1, N);
        animateTo(targetIdx);
    }

    // Initial render
    render();

    // ── Touch / pointer drag ─────────────────────────────
    let dragStartY = 0;
    let dragStartPos = 0;
    let isDragging = false;

    viewport?.addEventListener("pointerdown", (e: PointerEvent) => {
        if (isDetailView) return;
        e.stopPropagation();
        // Cancel any active spin — user takes over
        if (isSpinning) {
            if (spinAnimId) { cancelAnimationFrame(spinAnimId); spinAnimId = null; }
            isSpinning = false;
            isSettling = false;
            spinVelocity = 0;
            viewport?.classList.remove("roller-spinning");
            spinBtn?.classList.remove("spinning");
        }
        if (navAnimId) { cancelAnimationFrame(navAnimId); navAnimId = null; }
        isDragging = true;
        dragStartY = e.clientY;
        dragStartPos = scrollPos;
        viewport.setPointerCapture(e.pointerId);
    });

    viewport?.addEventListener("pointermove", (e: PointerEvent) => {
        if (!isDragging) return;
        e.stopPropagation();
        const delta = e.clientY - dragStartY;
        scrollPos = dragStartPos - delta / SLIDE_HEIGHT;
        render();
    });

    viewport?.addEventListener("pointerup", (e: PointerEvent) => {
        if (!isDragging) return;
        e.stopPropagation();
        isDragging = false;
        viewport.releasePointerCapture(e.pointerId);

        // Detect tap (no significant drag) and treat as slide click.
        // Pointer capture redirects the click event to the viewport,
        // so the track click handler never fires — handle it here.
        const dragDelta = Math.abs(e.clientY - dragStartY);
        if (dragDelta < 5) {
            // Determine which slot was tapped from the pointer Y position
            const rect = viewport.getBoundingClientRect();
            const relY = e.clientY - rect.top;
            const slotOffset = Math.floor(relY / SLIDE_HEIGHT - CENTER_OFFSET);
            const tappedIdx = mod(currentIdx + slotOffset, N);

            if (tappedIdx === currentIdx) {
                transitionToDetail();
            } else {
                targetIdx = tappedIdx;
                animateTo(tappedIdx);
            }
            return;
        }

        // Snap to nearest slide
        const nearest = mod(Math.round(scrollPos), N);
        targetIdx = nearest;
        currentIdx = nearest;
        animateTo(nearest, 200);
    });

    // ── Momentum-based spin ─────────────────────────────
    // Each click adds velocity. Friction decays it. Button spin speed matches.
    let spinVelocity = 0;      // slides per second
    let btnAngle = 0;          // cumulative button rotation in degrees
    let lastSpinTime = 0;

    const SPIN_KICK_MIN = 14;  // slides/sec added per click (min)
    const SPIN_KICK_MAX = 24;  // slides/sec added per click (max)
    const MAX_VELOCITY = 50;   // cap
    const FRICTION_MIN = 0.965;
    const FRICTION_MAX = 0.975;
    const SETTLE_THRESHOLD = 0.3;
    let currentFriction = 0.97;
    let spinStartIdx = 0;
    let isFirstSpin = true;
    const SKIP_FIRST_SPIN = new Set([
        slugToIndex["tdd-command-generator"],
        slugToIndex["tdd-with-ai-presentation"],
    ].filter(i => i != null));

    function spin() {
        if (isDetailView) return;
        if (navAnimId) { cancelAnimationFrame(navAnimId); navAnimId = null; }
        isSettling = false;

        const kick = SPIN_KICK_MIN + Math.random() * (SPIN_KICK_MAX - SPIN_KICK_MIN);
        spinVelocity = Math.min(spinVelocity + kick, MAX_VELOCITY);
        // Randomize friction each spin so duration feels different
        currentFriction = FRICTION_MIN + Math.random() * (FRICTION_MAX - FRICTION_MIN);

        if (!isSpinning) {
            isSpinning = true;
            spinStartIdx = currentIdx;
            lastSpinTime = performance.now();
            viewport?.classList.add("roller-spinning");
            spinBtn?.classList.add("spinning");
            spinAnimId = requestAnimationFrame(spinLoop);
        }
    }

    let isSettling = false;
    let settleStart = 0;
    let settleFrom = 0;
    let settleTo = 0;
    const SETTLE_DURATION = 280; // ms

    function spinLoop(now: number) {
        const dt = Math.min((now - lastSpinTime) / 1000, 0.05);
        lastSpinTime = now;

        // Settling phase — smooth ease into the target slot
        if (isSettling) {
            const t = Math.min((now - settleStart) / SETTLE_DURATION, 1);
            // Overshoot ease: slight bounce past target then back
            const eased = t < 0.7
                ? 1.2 * (t / 0.7) * (t / 0.7) * (3 - 2 * (t / 0.7)) // smooth overshoot
                : 1.0 + 0.2 * (1 - ((t - 0.7) / 0.3)) * (1 - ((t - 0.7) / 0.3)) * -1 + 0.2; // settle back
            // Simpler: use an elastic-ish ease
            const elastic = t === 1 ? 1 : 1 - Math.pow(2, -10 * t) * Math.cos((t * 10 - 0.75) * (2 * Math.PI / 3));
            scrollPos = settleFrom + (settleTo - settleFrom) * elastic;
            btnAngle += (1 - t) * 2; // gentle residual button rotation
            if (spinBtn) spinBtn.style.transform = `rotate(${btnAngle}deg)`;
            render();

            if (t >= 1) {
                scrollPos = mod(settleTo, N);
                currentIdx = mod(settleTo, N);
                targetIdx = currentIdx;
                isSpinning = false;
                isSettling = false;
                viewport?.classList.remove("roller-spinning");
                spinBtn?.classList.remove("spinning");
                spinAnimId = null;
                render();
                setTimeout(() => transitionToDetail(), 400);
                return;
            }

            spinAnimId = requestAnimationFrame(spinLoop);
            return;
        }

        // Momentum phase — friction decay
        spinVelocity *= currentFriction;
        scrollPos += spinVelocity * dt;
        btnAngle += spinVelocity * dt * 60;
        if (spinBtn) spinBtn.style.transform = `rotate(${btnAngle}deg)`;
        render();

        if (spinVelocity < SETTLE_THRESHOLD) {
            // Transition to settle phase
            isSettling = true;
            settleStart = now;
            settleFrom = scrollPos;
            settleTo = Math.round(scrollPos);
            // Never land on the same item we started on
            if (mod(settleTo, N) === mod(spinStartIdx, N)) {
                settleTo += (scrollPos >= spinStartIdx) ? 1 : -1;
            }
            // Don't land on TDD projects on the very first spin
            if (isFirstSpin && SKIP_FIRST_SPIN.has(mod(settleTo, N))) {
                settleTo += 1;
            }
            if (isFirstSpin) isFirstSpin = false;
            spinVelocity = 0;
        }

        spinAnimId = requestAnimationFrame(spinLoop);
    }

    // ── Detail view transitions ──────────────────────────
    function transitionToDetail() {
        if (isDetailView || isSpinning) return;
        isDetailView = true;
        const p = PROJECTS[currentIdx];
        if (detailCard) {
            const illustration = renderIllustration(PROJECT_SLUGS[currentIdx]);
            detailCard.innerHTML = `
                ${illustration}
                <div class="project-tag" data-key="${tagKey(p.tag)}">${p.tag}</div>
                <h3>${p.title}</h3>
                <p>${p.description}</p>
                <button class="back-button back-button--bottom" aria-label="${backBtn?.getAttribute("aria-label") ?? "Back"}">
                    <span class="back-arrow">&#x2190;</span> ${backBtn?.dataset.label ?? "Back"}
                </button>
            `;
            // Wire up the bottom back button
            detailCard.querySelector(".back-button--bottom")?.addEventListener("click", () => transitionToRoller());
        }
        section?.classList.add("detail-active");
        document.getElementById("slide-dots")?.classList.add("hidden");
        // Reset scroll positions so detail shows from the top
        const detailView = section?.querySelector(".detail-view") as HTMLElement | null;
        if (detailView) detailView.scrollTop = 0;
        const parentSlide = section?.closest(".keen-slider__slide") as HTMLElement | null;
        if (parentSlide) parentSlide.scrollTop = 0;
        // Tell keen-slider to freeze
        document.dispatchEvent(new CustomEvent("detail-view-toggle", { detail: { active: true } }));
        // Update URL hash for deep linking
        const slug = PROJECT_SLUGS[currentIdx];
        if (slug) {
            history.replaceState(null, "", "#" + slug);
        }
    }

    function transitionToRoller() {
        if (!isDetailView) return;
        isDetailView = false;
        section?.classList.remove("detail-active");
        document.getElementById("slide-dots")?.classList.remove("hidden");
        // Reset scroll positions so swiping works immediately
        const parentSlide = section?.closest(".keen-slider__slide");
        if (parentSlide) parentSlide.scrollTop = 0;
        const dv = section?.querySelector(".detail-view") as HTMLElement | null;
        if (dv) dv.scrollTop = 0;
        // Tell keen-slider to unfreeze
        document.dispatchEvent(new CustomEvent("detail-view-toggle", { detail: { active: false } }));
        // Clear URL hash
        history.replaceState(null, "", location.pathname);
    }

    // ── Event listeners ──────────────────────────────────
    spinBtn?.addEventListener("click", spin);
    openBtn?.addEventListener("click", () => transitionToDetail());
    backBtn?.addEventListener("click", () => transitionToRoller());
    arrowUp?.addEventListener("click", () => prev());
    arrowDown?.addEventListener("click", () => next());

    // Click a slide to open it
    track?.addEventListener("click", (e: MouseEvent) => {
        if (isSpinning) return;
        const slide = (e.target as HTMLElement).closest(".roller-slide") as HTMLElement | null;
        if (!slide) return;
        const idx = Number(slide.dataset.index);
        if (idx === currentIdx) {
            transitionToDetail();
        } else {
            targetIdx = idx;
            animateTo(idx);
        }
    });

    // Keyboard nav — stopPropagation prevents the global keen-slider
    // ArrowUp/Down handler from also firing a slide change.
    viewport?.setAttribute("tabindex", "0");
    viewport?.addEventListener("keydown", (e: KeyboardEvent) => {
        if (isSpinning || isDetailView) return;
        if (e.key === "ArrowUp") { e.preventDefault(); e.stopPropagation(); prev(); }
        if (e.key === "ArrowDown") { e.preventDefault(); e.stopPropagation(); next(); }
        if (e.key === "Enter" || e.key === " ") { e.preventDefault(); e.stopPropagation(); spin(); }
    });

    let wheelAccum = 0;
    section?.addEventListener("wheel", (e: WheelEvent) => {
        if (!viewport?.contains(e.target as Node)) return;
        e.stopPropagation();
        e.preventDefault();
        if (isSpinning || isDetailView) {
            wheelAccum = 0;
            return;
        }

        // Reset accumulator on direction reversal to avoid sluggish response
        if ((wheelAccum > 0 && e.deltaY < 0) || (wheelAccum < 0 && e.deltaY > 0)) {
            wheelAccum = 0;
        }
        // Accumulate small deltas (trackpad) before triggering a step
        wheelAccum += e.deltaY;
        const threshold = 60;
        if (Math.abs(wheelAccum) >= threshold) {
            if (wheelAccum > 0) next(); else prev();
            wheelAccum = 0;
        }
    }, { capture: true, passive: false });

    document.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Escape" && isDetailView) { e.preventDefault(); transitionToRoller(); }
    });

    // Prevent touch/mouse events on the detail view from propagating to
    // keen-slider, which would interpret them as slide-change swipes.
    const detailViewEl = section?.querySelector(".detail-view") as HTMLElement | null;
    function stopIfDetail(e: Event) {
        if (isDetailView) e.stopPropagation();
    }
    detailViewEl?.addEventListener("mousedown", stopIfDetail);
    detailViewEl?.addEventListener("touchstart", stopIfDetail, { passive: true });

    // Browser back/forward: close detail if hash no longer matches
    window.addEventListener("popstate", () => {
        const hash = location.hash.replace(/^#/, "");
        if (isDetailView && !(hash in slugToIndex)) {
            transitionToRoller();
        } else if (!isDetailView && hash in slugToIndex) {
            const idx = slugToIndex[hash];
            targetIdx = idx;
            animateTo(idx, 300);
            // Open detail after animation
            setTimeout(() => transitionToDetail(), 350);
        }
    });

    // ── Auto-spin on enter, reset on leave ─────────────
    const PROJECTS_SLIDE_INDEX = 1;
    let hasAutoSpun = false;
    let isOnProjectsSlide = false;

    function autoSpin() {
        if (isSpinning || isDetailView) return;
        spinVelocity = 28 + Math.random() * 8;
        currentFriction = FRICTION_MAX;
        isSpinning = true;
        spinStartIdx = currentIdx;
        lastSpinTime = performance.now();
        viewport?.classList.add("roller-spinning");
        spinBtn?.classList.add("spinning");
        spinAnimId = requestAnimationFrame(spinLoop);
    }

    function silentReset() {
        if (spinAnimId) { cancelAnimationFrame(spinAnimId); spinAnimId = null; }
        if (navAnimId) { cancelAnimationFrame(navAnimId); navAnimId = null; }
        isSpinning = false;
        isSettling = false;
        spinVelocity = 0;
        isDetailView = false;
        section?.classList.remove("detail-active");
        viewport?.classList.remove("roller-spinning");
        spinBtn?.classList.remove("spinning");
        document.getElementById("slide-dots")?.classList.remove("hidden");
        // Clear URL hash so returning to the projects slide doesn't re-open detail
        if (location.hash) history.replaceState(null, "", location.pathname);
        // Reset parent keen-slider slide's scroll position so the roulette
        // isn't offset when returning after viewing a scrolled detail card
        const parentSlide = section?.closest(".keen-slider__slide");
        if (parentSlide) parentSlide.scrollTop = 0;
        // Scramble position so next visit looks different
        const randomStart = Math.floor(Math.random() * N);
        scrollPos = randomStart;
        currentIdx = randomStart;
        targetIdx = randomStart;
        render();
    }

    document.addEventListener("slide-changed", ((e: CustomEvent) => {
        const idx = e.detail.index;
        if (idx === PROJECTS_SLIDE_INDEX) {
            if (!isOnProjectsSlide) {
                isOnProjectsSlide = true;

                // Deep link: if hash matches a project slug, navigate directly
                const hash = location.hash.replace(/^#/, "");
                if (hash && hash in slugToIndex) {
                    hasAutoSpun = true; // skip auto-spin
                    const target = slugToIndex[hash];
                    targetIdx = target;
                    animateTo(target, 300);
                    setTimeout(() => transitionToDetail(), 350);
                } else if (!hasAutoSpun) {
                    hasAutoSpun = true;
                    autoSpin();
                }
            }
        } else {
            if (isOnProjectsSlide) {
                isOnProjectsSlide = false;
                silentReset();
            }
        }
    }) as EventListener);

</script>

