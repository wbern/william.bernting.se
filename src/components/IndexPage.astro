---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Projects from "../components/Projects.astro";
import Stats from "../components/Stats.astro";
import Timeline from "../components/Timeline.astro";
import Skills from "../components/Skills.astro";
import Quote from "../components/Quote.astro";
import SlideDots from "../components/SlideDots.astro";
import PdfButton from "../components/PdfButton.astro";
import { useTranslations } from "../i18n/utils";
import type { Lang } from "../i18n/ui";

const lang = (Astro.currentLocale ?? "sv") as Lang;
const t = useTranslations(lang);
---

<Layout title={t("meta.title")} description={t("meta.description")}>
    <div id="slider" class="keen-slider">
        <div class="keen-slider__slide" data-keen-slider-scrollable style="overflow-y: scroll">
            <Hero />
        </div>
        <div class="keen-slider__slide" data-keen-slider-scrollable style="overflow-y: scroll">
            <Projects />
        </div>
        <div class="keen-slider__slide" data-keen-slider-scrollable style="overflow-y: scroll">
            <Stats />
        </div>
        <div class="keen-slider__slide" data-keen-slider-scrollable style="overflow-y: scroll">
            <Timeline />
        </div>
        <div class="keen-slider__slide" data-keen-slider-scrollable style="overflow-y: scroll">
            <Skills />
        </div>
        <div class="keen-slider__slide section-quote" data-keen-slider-scrollable style="overflow-y: scroll">
            <Quote />
        </div>
    </div>

    <SlideDots count={6} />
    <PdfButton />
</Layout>

<script>
    import KeenSlider from "keen-slider";

    // Mousewheel plugin for keen-slider — one slide per swipe.
    // Mac trackpads produce inertia tails with decaying deltas after a flick.
    // Strategy: lock after triggering, stay locked while deltas decay (inertia),
    // but unlock immediately if a fresh high-delta gesture breaks the pattern.
    function WheelControls(slider: any) {
        let locked = false;
        let unlockTimer: ReturnType<typeof setTimeout> | null = null;
        let recentDelta = 0; // smoothed recent absolute delta
        const QUIET_MS = 200;
        const SPIKE_RATIO = 1.5; // new delta must be 1.5× recent to count as fresh gesture
        const SLIDE_COOLDOWN_MS = 600; // hard cooldown between slide transitions
        let lastSlideTime = 0;
        const BOUNDARY_GRACE_MS = 300; // grace period after hitting scroll boundary
        let lastScrollableTime = 0; // last time content was actually scrollable

        function currentSlideEl(): HTMLElement | null {
            const idx = slider.track.details.rel;
            return slider.slides[idx] ?? null;
        }

        function elementCanScroll(el: HTMLElement, deltaY: number): boolean {
            const tolerance = 1;
            if (deltaY > 0) {
                return el.scrollTop + el.clientHeight < el.scrollHeight - tolerance;
            }
            return el.scrollTop > tolerance;
        }

        /** Walk from event target up to slide, checking for any scrollable ancestor. */
        function anyAncestorCanScroll(target: HTMLElement, slide: HTMLElement, deltaY: number): boolean {
            let node: HTMLElement | null = target;
            while (node && node !== slider.container) {
                const ov = getComputedStyle(node).overflowY;
                if ((ov === "auto" || ov === "scroll") && elementCanScroll(node, deltaY)) {
                    return true;
                }
                node = node.parentElement as HTMLElement | null;
            }
            return false;
        }

        slider.on("created", () => {
            slider.container.addEventListener(
                "wheel",
                (e: WheelEvent) => {
                    const slide = currentSlideEl();
                    const canScroll = slide && anyAncestorCanScroll(e.target as HTMLElement, slide, e.deltaY);
                    if (canScroll) {
                        recentDelta = 0;
                        locked = false;
                        lastScrollableTime = performance.now();
                        return;
                    }

                    e.preventDefault();

                    // Grace period: if content was just scrollable, absorb
                    // events briefly so hitting a scroll boundary doesn't
                    // immediately trigger a slide change.
                    if (performance.now() - lastScrollableTime < BOUNDARY_GRACE_MS) {
                        return;
                    }

                    const absDelta = Math.abs(e.deltaY);

                    // Quiet-period fallback: unlock if no events for QUIET_MS
                    if (unlockTimer) clearTimeout(unlockTimer);
                    unlockTimer = setTimeout(() => {
                        locked = false;
                        recentDelta = 0;
                    }, QUIET_MS);

                    if (locked) {
                        // Check for a fresh gesture: delta spikes above decaying trend
                        if (absDelta > recentDelta * SPIKE_RATIO && absDelta > 3) {
                            locked = false; // let it through below
                        } else {
                            // Still inertia — track the decay and swallow
                            recentDelta = recentDelta * 0.8 + absDelta * 0.2;
                            return;
                        }
                    }

                    // Hard cooldown: prevent rapid successive slide changes
                    const now = performance.now();
                    if (now - lastSlideTime < SLIDE_COOLDOWN_MS) {
                        locked = true;
                        recentDelta = absDelta;
                        return;
                    }

                    // Trigger slide change and lock
                    locked = true;
                    recentDelta = absDelta;
                    lastSlideTime = now;

                    if (e.deltaY > 0) {
                        slider.next();
                    } else {
                        slider.prev();
                    }
                },
                { passive: false }
            );
        });
    }

    // Reveal animations for current slide
    function revealSlide(index: number) {
        const slides = document.querySelectorAll(".keen-slider__slide");
        slides.forEach((slide, i) => {
            const reveals = slide.querySelectorAll(".reveal");
            if (i === index) {
                reveals.forEach((el) => el.classList.add("visible"));
            } else {
                reveals.forEach((el) => el.classList.remove("visible"));
            }
        });
    }

    // Update dot navigation
    function updateDots(index: number) {
        const dots = document.querySelectorAll(".slide-dot");
        dots.forEach((dot, i) => {
            dot.classList.toggle("active", i === index);
        });
    }

    // Initialize slider
    const sliderEl = document.getElementById("slider");
    if (sliderEl) {
        const slider = new KeenSlider(
            sliderEl,
            {
                vertical: true,
                slides: { perView: 1 },
                defaultAnimation: { duration: 500 },
                detailsChanged: (s) => {
                    const slideIndex = s.track.details.rel;
                    updateDots(slideIndex);
                    document.dispatchEvent(new CustomEvent("slide-changed", { detail: { index: slideIndex } }));
                },
                animationEnded: (s) => {
                    revealSlide(s.track.details.rel);
                },
                created: () => {
                    // Reveal first slide immediately
                    revealSlide(0);
                },
            },
            [WheelControls]
        );

        // Deep link: if URL has a hash, navigate to projects slide
        if (location.hash) {
            requestAnimationFrame(() => {
                slider.moveToIdx(1);
            });
        }

        // Dot click navigation
        document.querySelectorAll(".slide-dot").forEach((dot) => {
            dot.addEventListener("click", () => {
                const slideIndex = Number(
                    (dot as HTMLElement).dataset.slide
                );
                slider.moveToIdx(slideIndex);
            });
        });

        // Keyboard navigation (with cooldown to prevent rapid-fire from key repeat)
        let lastKeySlideTime = 0;
        const KEY_COOLDOWN_MS = 600;
        document.addEventListener("keydown", (e) => {
            if (e.key === "ArrowDown" || e.key === "PageDown") {
                e.preventDefault();
                const now = performance.now();
                if (now - lastKeySlideTime < KEY_COOLDOWN_MS) return;
                lastKeySlideTime = now;
                slider.next();
            } else if (e.key === "ArrowUp" || e.key === "PageUp") {
                e.preventDefault();
                const now = performance.now();
                if (now - lastKeySlideTime < KEY_COOLDOWN_MS) return;
                lastKeySlideTime = now;
                slider.prev();
            }
        });
    }

    // Redirect print to the CV page (which has proper print styles)
    const cvPath = document.querySelector<HTMLAnchorElement>(".pdf-btn")?.href;
    if (cvPath) {
        const cvPrintUrl = cvPath + "?print=1";

        // Intercept Ctrl+P / Cmd+P
        document.addEventListener("keydown", (e) => {
            if ((e.ctrlKey || e.metaKey) && e.key === "p") {
                e.preventDefault();
                window.location.href = cvPrintUrl;
            }
        });

        // Fallback for File > Print menu
        window.addEventListener("beforeprint", () => {
            window.location.href = cvPrintUrl;
        });
    }
</script>
