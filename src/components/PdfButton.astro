---
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const cvHref = lang === "sv" ? "/cv" : "/en/cv";
---

<a class="pdf-btn" href={cvHref}>
    <svg viewBox="0 0 24 24">
        <path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 2l5 5h-5V4zm-3 13H8v-2h2v2zm4 0h-2v-2h2v2zm-4-4H8v-2h2v2zm4 0h-2v-2h2v-2z" />
    </svg>
    <span class="pdf-btn-text">CV</span>
</a>
