---
import { useTranslations } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
---

<div class="section-inner">
    <div class="section-label reveal">{t("stats.label")}</div>
    <h2 class="section-heading reveal reveal-delay-1">
        {t("stats.heading.before")}<span class="highlight">{t("stats.heading.highlight")}</span>{t("stats.heading.after")}
    </h2>

    <div class="stats-grid">
        <div class="stat reveal reveal-delay-1">
            <div class="stat-number">{t("stats.production.value")}</div>
            <div class="stat-label">{t("stats.production")}</div>
        </div>
        <div class="stat reveal reveal-delay-2">
            <div class="stat-number">{t("stats.users.value")}</div>
            <div class="stat-label">{t("stats.users")}</div>
        </div>
        <div class="stat reveal reveal-delay-3">
            <div class="stat-number">{t("stats.teams.value")}</div>
            <div class="stat-label">{t("stats.teams")}</div>
        </div>
        <div class="stat reveal reveal-delay-4">
            <div class="stat-number">{t("stats.experience.value")}</div>
            <div class="stat-label">{t("stats.experience")}</div>
        </div>
        <div class="stat reveal reveal-delay-4">
            <div class="stat-number">{t("stats.coderate.value")}</div>
            <div class="stat-label">{t("stats.coderate")}</div>
        </div>
    </div>
</div>

<style>
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 30px;
    }

    .stat {
        text-align: center;
        padding: 20px;
        min-width: 0;
    }

    .stat-number {
        font-size: clamp(48px, 6vw, 72px);
        font-weight: 900;
        color: var(--purple);
        line-height: 1;
        margin-bottom: 8px;
        font-family: var(--mono);
    }

    .stat-label {
        font-size: 16px;
        color: var(--text-dim);
    }

    @media (max-width: 600px) {
        .stats-grid { grid-template-columns: 1fr 1fr; }
        .stat:last-child { display: none; }
        .stat-number { font-size: clamp(32px, 8vw, 48px); }
    }

    @media print {
        .stats-grid { grid-template-columns: repeat(5, 1fr); gap: 4px; }
        .stat { padding: 4px 4px; }
        .stat-number { font-size: 22px; margin-bottom: 1px; }
        .stat-label { font-size: 8px; }
    }
</style>
