---
---

<div class="section-inner">
    <div class="section-label reveal">By the numbers</div>
    <h2 class="section-heading reveal reveal-delay-1">
        It's not a <span class="highlight">phase</span>.
    </h2>

    <div class="stats-grid">
        <div class="stat reveal reveal-delay-1">
            <div class="stat-number">47</div>
            <div class="stat-label">prototypes shipped in the last 12 months</div>
        </div>
        <div class="stat reveal reveal-delay-2">
            <div class="stat-number">5k</div>
            <div class="stat-label">users on a single internal tool</div>
        </div>
        <div class="stat reveal reveal-delay-3">
            <div class="stat-number">14</div>
            <div class="stat-label">dev teams supported at one company</div>
        </div>
        <div class="stat reveal reveal-delay-4">
            <div class="stat-number">10y</div>
            <div class="stat-label">of professional software development</div>
        </div>
    </div>
</div>

<style>
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 30px;
    }

    .stat {
        text-align: center;
        padding: 20px;
    }

    .stat-number {
        font-size: clamp(48px, 6vw, 72px);
        font-weight: 900;
        color: var(--purple);
        line-height: 1;
        margin-bottom: 8px;
        font-family: var(--mono);
    }

    .stat-label {
        font-size: 16px;
        color: var(--text-dim);
    }

    @media (max-width: 600px) {
        .stats-grid { grid-template-columns: 1fr 1fr; }
    }

    @media print {
        .stats-grid { grid-template-columns: repeat(4, 1fr); gap: 4px; }
        .stat { padding: 4px 4px; }
        .stat-number { font-size: 22px; margin-bottom: 1px; }
        .stat-label { font-size: 8px; }
    }
</style>
