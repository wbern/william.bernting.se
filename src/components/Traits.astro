---
import { useTranslations } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";
import { getTraitRows } from "../i18n/traits";
import MarqueeField from "./MarqueeField.astro";

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const rows = getTraitRows(lang);
---

<div class="section-inner">
    <div class="section-label">{t("traits.label")}</div>
    <h2 class="section-heading">
        {t("traits.heading.before")}<span class="highlight">{t("traits.heading.highlight")}</span>{t("traits.heading.after")}
    </h2>

    <MarqueeField rows={rows} />
</div>

<!-- print fallback (hidden in browser, shown in print) -->
<div class="traits-print-fallback">
    <div class="section-label">{t("traits.label")}</div>
    <h2 class="section-heading">{t("traits.heading.before")}<span class="highlight">{t("traits.heading.highlight")}</span>{t("traits.heading.after")}</h2>
    <div class="traits-print-grid">
        <div class="traits-print-item"><h3>{rows[0].items[0]}</h3><p>{t("print.traits.ai")}</p></div>
        <div class="traits-print-item"><h3>{rows[0].items[1]}</h3><p>{t("print.traits.team")}</p></div>
        <div class="traits-print-item"><h3>{rows[0].items[2]}</h3><p>{t("print.traits.debug")}</p></div>
        <div class="traits-print-item"><h3>{rows[0].items[3]}</h3><p>{t("print.traits.legacy")}</p></div>
    </div>
</div>

<style>
    /* print fallback */
    .traits-print-fallback { display: none; }

    @media print {
        .section-inner { display: none !important; }
        .traits-print-fallback { display: block !important; }
        .traits-print-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
        .traits-print-item { background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px; }
        .traits-print-item h3 { font-size: 11px; margin-bottom: 2px; }
        .traits-print-item p { font-size: 9px; line-height: 1.3; color: var(--text-dim); }
    }
</style>
