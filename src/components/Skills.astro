---
import { useTranslations } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const skills = [
    { label: "Agentic AI", featured: true },
    { label: "Test-Driven Development", featured: true },
    { label: "Claude / LLMs", featured: true },
    { label: "Node.js", featured: false },
    { label: "TypeScript", featured: false },
    { label: "React", featured: false },
    { label: "Next.js", featured: false },
    { label: "C#", featured: false },
    { label: "Vue", featured: false },
    { label: "Angular", featured: false },
    { label: "DevOps / CI/CD", featured: false },
    { label: "AWS / Azure", featured: false },
    { label: "Servant Leadership", featured: false },
];
---

{/* Canvas fills the entire slide; heading floats on top */}
<div class="skills-pit" data-skills={JSON.stringify(skills)}>
    <canvas class="skills-canvas"></canvas>
</div>
<div class="section-inner skills-heading-overlay" style="text-align: center;">
    <div class="section-label reveal">{t("skills.label")}</div>
    <h2 class="section-heading reveal reveal-delay-1">
        {t("skills.heading.before")}<span class="highlight">{t("skills.heading.highlight")}</span>{t("skills.heading.after")}
    </h2>
</div>

<!-- Print fallback -->
<div class="skills-print-fallback">
    <div class="section-inner" style="text-align: center;">
        <div class="section-label">{t("skills.label")}</div>
        <h2 class="section-heading">{t("skills.heading.before")}<span class="highlight">{t("skills.heading.highlight")}</span>{t("skills.heading.after")}</h2>
        <div class="skills-cloud-print">
            {skills.map(s => (
                <span class:list={["skill-pill-print", { featured: s.featured }]}>{s.label}</span>
            ))}
        </div>
    </div>
</div>

<style>
    /* Canvas covers the entire slide */
    .skills-pit {
        position: absolute;
        inset: 0;
        overflow: hidden;
        z-index: 0;
    }

    .skills-canvas {
        width: 100%;
        height: 100%;
        display: block;
        cursor: grab;
    }

    .skills-canvas:active {
        cursor: grabbing;
    }

    /* Heading floats at top of slide, pointer-events pass through to canvas */
    .skills-heading-overlay {
        position: absolute;
        top: 60px;
        left: 40px;
        right: 40px;
        z-index: 1;
        pointer-events: none;
    }

    @media (max-width: 600px) {
        .skills-heading-overlay {
            top: 40px;
            left: 20px;
            right: 20px;
        }
    }

    /* Print */
    .skills-print-fallback { display: none; }
    @media print {
        .skills-pit { display: none !important; }
        .skills-heading-overlay { display: none !important; }
        .skills-print-fallback { display: block !important; }
        .skills-cloud-print {
            display: flex; flex-wrap: wrap; gap: 3px; justify-content: center;
        }
        .skill-pill-print {
            font-family: var(--mono); font-size: 8px; padding: 2px 6px;
            border-radius: 100px; border: 1px solid var(--border);
            color: var(--text-dim);
        }
        .skill-pill-print.featured {
            border-color: var(--purple-dim); color: var(--purple);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .skills-canvas { display: none; }
        .skills-heading-overlay { display: none; }
        .skills-print-fallback {
            display: block !important;
        }
        .skills-cloud-print {
            display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;
        }
        .skill-pill-print {
            font-family: var(--mono); font-size: 14px; padding: 8px 18px;
            border-radius: 100px; border: 1px solid var(--border);
            background: var(--bg-card); color: var(--text-dim);
        }
        .skill-pill-print.featured {
            border-color: var(--purple-dim); color: var(--purple);
            background: var(--purple-glow);
        }
    }
</style>

<script>
(function () {
    const pit = document.querySelector<HTMLElement>('.skills-pit');
    if (!pit) return;
    const canvas = pit.querySelector<HTMLCanvasElement>('.skills-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;

    const skillsData: { label: string; featured: boolean }[] =
        JSON.parse(pit.dataset.skills || '[]');
    if (!skillsData.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // ─── Physics constants ───
    const GRAVITY   = 500;
    const BOUNCE    = 0.35;
    const FRICTION  = 0.6;
    const AIR_DRAG  = 0.997;
    const ROT_DRAG  = 0.92;
    const ROT_SPRING = 8;
    const ROT_MAX   = 0.25;
    const DT_CAP    = 0.033;
    const SPAWN_INTERVAL = 350;
    const MAX_PILLS = 50;
    const COL_GAP   = 4;

    // ─── Pill rendering ───
    const PILL_H    = 32;
    const PILL_PAD  = 18;
    const FONT      = '600 13px "JetBrains Mono", monospace';
    const PURPLE    = '#9b4dca';
    const PURPLE_BG = 'rgba(155, 77, 202, 0.15)';
    const PURPLE_BORDER = '#7b2d8e';
    const BORDER    = '#222233';
    const BG_CARD   = '#13131a';
    const TEXT_DIM  = '#8888a0';

    interface Pill {
        x: number; y: number;
        vx: number; vy: number;
        r: number; vr: number;
        w: number; h: number;
        label: string;
        featured: boolean;
        settled: number;
        alive: boolean;
        restR: number;
        opacity: number;
        age: number;
        grabbed: boolean;
    }

    const pills: Pill[] = [];
    let spawnIdx = 0;
    let lastSpawn = 0;
    let animId: number | null = null;
    let running = false;
    let W = 0, H = 0;

    // ─── Drag state ───
    let dragPill: Pill | null = null;
    let dragOffX = 0, dragOffY = 0;
    let prevMouseX = 0, prevMouseY = 0;
    let mouseVX = 0, mouseVY = 0;

    function measurePill(label: string): number {
        ctx.font = FONT;
        return ctx.measureText(label).width + PILL_PAD * 2;
    }

    function resize() {
        const dpr = window.devicePixelRatio || 1;
        // Use actual pit dimensions (absolute-positioned, inset:0 within slide)
        W = pit.offsetWidth;
        H = pit.offsetHeight;
        canvas.width = W * dpr;
        canvas.height = H * dpr;
        canvas.style.width = W + 'px';
        canvas.style.height = H + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function spawnPill() {
        const aliveCount = pills.filter(p => p.alive).length;
        if (aliveCount >= MAX_PILLS) return;
        const skill = skillsData[spawnIdx % skillsData.length];
        spawnIdx++;
        const w = measurePill(skill.label);
        const restR = (Math.random() - 0.5) * ROT_MAX;
        pills.push({
            x: Math.random() * (W - w - 20) + 10,
            y: -PILL_H - Math.random() * 40,
            vx: (Math.random() - 0.5) * 60,
            vy: Math.random() * 30 + 10,
            r: (Math.random() - 0.5) * 0.15,
            vr: (Math.random() - 0.5) * 0.8,
            w, h: PILL_H,
            label: skill.label,
            featured: skill.featured,
            settled: 0,
            alive: true,
            restR,
            opacity: 1,
            age: spawnIdx,
            grabbed: false,
        });
    }

    function pillsOverlap(a: Pill, b: Pill): { nx: number; ny: number; overlap: number } | null {
        const ax = a.x - COL_GAP, ay = a.y - COL_GAP;
        const aw = a.w + COL_GAP * 2, ah = a.h + COL_GAP * 2;
        const bx = b.x - COL_GAP, by = b.y - COL_GAP;
        const bw = b.w + COL_GAP * 2, bh = b.h + COL_GAP * 2;

        const overlapX = Math.min(ax + aw, bx + bw) - Math.max(ax, bx);
        const overlapY = Math.min(ay + ah, by + bh) - Math.max(ay, by);

        if (overlapX <= 0 || overlapY <= 0) return null;

        if (overlapX < overlapY) {
            const nx = (a.x + a.w / 2) < (b.x + b.w / 2) ? -1 : 1;
            return { nx, ny: 0, overlap: overlapX };
        } else {
            const ny = (a.y + a.h / 2) < (b.y + b.h / 2) ? -1 : 1;
            return { nx: 0, ny, overlap: overlapY };
        }
    }

    // ─── Hit-test: find pill under cursor ───
    function hitTest(mx: number, my: number): Pill | null {
        // Iterate in reverse so topmost (last drawn) pill is picked first
        for (let i = pills.length - 1; i >= 0; i--) {
            const p = pills[i];
            if (!p.alive || p.opacity < 0.5) continue;
            if (mx >= p.x && mx <= p.x + p.w && my >= p.y && my <= p.y + p.h) {
                return p;
            }
        }
        return null;
    }

    // ─── Mouse / Touch handlers ───
    function getCanvasPos(e: MouseEvent | Touch): { x: number; y: number } {
        const rect = canvas.getBoundingClientRect();
        return { x: e.clientX - rect.left, y: e.clientY - rect.top };
    }

    function onPointerDown(mx: number, my: number) {
        const p = hitTest(mx, my);
        if (!p) return;
        dragPill = p;
        p.grabbed = true;
        p.settled = 0;
        dragOffX = mx - p.x;
        dragOffY = my - p.y;
        prevMouseX = mx;
        prevMouseY = my;
        mouseVX = 0;
        mouseVY = 0;
    }

    function onPointerMove(mx: number, my: number) {
        if (!dragPill) return;
        // Track velocity for throw
        mouseVX = (mx - prevMouseX) * 60; // scale to ~px/s at 60fps
        mouseVY = (my - prevMouseY) * 60;
        prevMouseX = mx;
        prevMouseY = my;

        dragPill.x = mx - dragOffX;
        dragPill.y = my - dragOffY;
        dragPill.vx = 0;
        dragPill.vy = 0;
    }

    function onPointerUp() {
        if (!dragPill) return;
        // Throw with tracked velocity
        dragPill.vx = mouseVX;
        dragPill.vy = mouseVY;
        dragPill.vr = (Math.random() - 0.5) * 3 * Math.min(1, Math.abs(mouseVX) / 500);
        dragPill.grabbed = false;
        dragPill = null;
    }

    // Stop propagation when dragging to prevent keen-slider from swiping
    function stopIfDragging(e: Event) {
        if (dragPill) { e.stopPropagation(); }
    }

    // Mouse events
    canvas.addEventListener('mousedown', (e) => {
        const pos = getCanvasPos(e);
        onPointerDown(pos.x, pos.y);
        if (dragPill) e.stopPropagation();
    });
    canvas.addEventListener('mousemove', (e) => {
        const pos = getCanvasPos(e);
        onPointerMove(pos.x, pos.y);
        stopIfDragging(e);
    });
    canvas.addEventListener('mouseup', (e) => {
        stopIfDragging(e);
        onPointerUp();
    });
    canvas.addEventListener('mouseleave', onPointerUp);

    // Touch events
    canvas.addEventListener('touchstart', (e) => {
        if (e.touches.length !== 1) return;
        const pos = getCanvasPos(e.touches[0]);
        const hit = hitTest(pos.x, pos.y);
        if (hit) {
            e.preventDefault();
            e.stopPropagation();
            onPointerDown(pos.x, pos.y);
        }
    }, { passive: false });
    canvas.addEventListener('touchmove', (e) => {
        if (!dragPill) return;
        e.preventDefault();
        e.stopPropagation();
        const pos = getCanvasPos(e.touches[0]);
        onPointerMove(pos.x, pos.y);
    }, { passive: false });
    canvas.addEventListener('touchend', (e) => {
        if (dragPill) e.stopPropagation();
        onPointerUp();
    });
    canvas.addEventListener('touchcancel', onPointerUp);

    function step(dt: number) {
        for (const p of pills) {
            if (!p.alive || p.grabbed) continue;

            p.vy += GRAVITY * dt;
            p.vx *= AIR_DRAG;
            p.vy *= AIR_DRAG;
            p.vr *= ROT_DRAG;

            p.vr += -ROT_SPRING * (p.r - p.restR) * dt;

            p.x += p.vx * dt;
            p.y += p.vy * dt;
            p.r += p.vr * dt;

            const FLOOR = H;
            if (p.y + p.h > FLOOR) {
                p.y = FLOOR - p.h;
                if (Math.abs(p.vy) > 15) {
                    p.vr += (Math.random() - 0.5) * 1.2;
                }
                p.vy = -p.vy * BOUNCE;
                p.vx *= FRICTION;
            }

            // Walls
            if (p.x < 0) { p.x = 0; p.vx = -p.vx * BOUNCE; }
            if (p.x + p.w > W) { p.x = W - p.w; p.vx = -p.vx * BOUNCE; }

            // Settle
            if (Math.abs(p.vx) < 1.5 && Math.abs(p.vy) < 1.5 &&
                Math.abs(p.vr) < 0.1 && p.y + p.h >= H - 2) {
                p.settled++;
            } else {
                p.settled = 0;
            }

            // Fade dying
            if (p.opacity < 1) {
                p.opacity -= 0.02;
                if (p.opacity <= 0) p.alive = false;
            }
        }

        // Collisions
        for (let iter = 0; iter < 3; iter++) {
            for (let i = 0; i < pills.length; i++) {
                const a = pills[i];
                if (!a.alive) continue;
                for (let j = i + 1; j < pills.length; j++) {
                    const b = pills[j];
                    if (!b.alive) continue;
                    const hit = pillsOverlap(a, b);
                    if (!hit) continue;

                    const { nx, ny, overlap } = hit;

                    // If one is grabbed, only push the other
                    if (a.grabbed) {
                        b.x -= nx * overlap;
                        b.y -= ny * overlap;
                    } else if (b.grabbed) {
                        a.x += nx * overlap;
                        a.y += ny * overlap;
                    } else {
                        a.x += nx * overlap * 0.55;
                        a.y += ny * overlap * 0.55;
                        b.x -= nx * overlap * 0.55;
                        b.y -= ny * overlap * 0.55;
                    }

                    if (iter === 0 && !a.grabbed && !b.grabbed) {
                        const dvx = a.vx - b.vx;
                        const dvy = a.vy - b.vy;
                        const impulse = (dvx * nx + dvy * ny) * 0.5;

                        a.vx -= impulse * nx * BOUNCE;
                        a.vy -= impulse * ny * BOUNCE;
                        b.vx += impulse * nx * BOUNCE;
                        b.vy += impulse * ny * BOUNCE;

                        a.vr += (Math.random() - 0.5) * 0.2;
                        b.vr += (Math.random() - 0.5) * 0.2;
                    } else if (iter === 0) {
                        // Grabbed pill shoves others
                        const other = a.grabbed ? b : a;
                        other.vx += nx * (a.grabbed ? -1 : 1) * 150;
                        other.vy += ny * (a.grabbed ? -1 : 1) * 150;
                        other.vr += (Math.random() - 0.5) * 1;
                    }
                }
                if (!a.grabbed) {
                    if (a.y + a.h > H) { a.y = H - a.h; a.vy = Math.min(a.vy, 0); }
                    if (a.x < 0) a.x = 0;
                    if (a.x + a.w > W) a.x = W - a.w;
                }
            }
        }

        // Hard clamp: no pill below floor or outside walls
        for (const p of pills) {
            if (!p.alive || p.grabbed) continue;
            if (p.y + p.h > H) { p.y = H - p.h; p.vy = Math.min(p.vy, 0); }
            if (p.x < 0) p.x = 0;
            if (p.x + p.w > W) p.x = W - p.w;
        }
    }

    function drawPill(p: Pill) {
        ctx.save();
        ctx.globalAlpha = p.opacity;
        const cx = p.x + p.w / 2;
        const cy = p.y + p.h / 2;
        ctx.translate(cx, cy);
        ctx.rotate(p.r);

        const hw = p.w / 2;
        const hh = p.h / 2;
        const radius = hh;

        ctx.beginPath();
        ctx.moveTo(-hw + radius, -hh);
        ctx.lineTo(hw - radius, -hh);
        ctx.arcTo(hw, -hh, hw, -hh + radius, radius);
        ctx.lineTo(hw, hh - radius);
        ctx.arcTo(hw, hh, hw - radius, hh, radius);
        ctx.lineTo(-hw + radius, hh);
        ctx.arcTo(-hw, hh, -hw, hh - radius, radius);
        ctx.lineTo(-hw, -hh + radius);
        ctx.arcTo(-hw, -hh, -hw + radius, -hh, radius);
        ctx.closePath();

        ctx.fillStyle = p.featured ? PURPLE_BG : BG_CARD;
        ctx.fill();

        ctx.strokeStyle = p.featured ? PURPLE_BORDER : BORDER;
        ctx.lineWidth = 1;
        ctx.stroke();

        ctx.font = FONT;
        ctx.fillStyle = p.featured ? PURPLE : TEXT_DIM;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(p.label, 0, 0.5);

        ctx.restore();
    }

    function draw() {
        ctx.clearRect(0, 0, W, H);
        for (const p of pills) {
            if (p.alive) drawPill(p);
        }
    }

    function start() {
        if (running) return;
        running = true;
        pills.length = 0;
        spawnIdx = 0;
        lastSpawn = 0;
        resize();

        let prev = performance.now();

        function tick(now: number) {
            const dt = Math.min((now - prev) / 1000, DT_CAP);
            prev = now;

            if (now - lastSpawn > SPAWN_INTERVAL) {
                spawnPill();
                lastSpawn = now;
            }

            // Recycle when pile gets high
            const highMark = H * 0.15;
            const alivePills = pills.filter(p => p.alive && p.opacity === 1 && !p.grabbed);
            const anyHigh = alivePills.some(p => p.y < highMark && p.settled > 30);
            if (anyHigh) {
                const settled = alivePills.filter(p => p.settled > 60).sort((a, b) => a.age - b.age);
                for (let k = 0; k < Math.min(3, settled.length); k++) {
                    settled[k].opacity = 0.99;
                }
            }

            // GC dead pills
            for (let k = pills.length - 1; k >= 0; k--) {
                if (!pills[k].alive) pills.splice(k, 1);
            }

            step(dt);
            draw();

            animId = requestAnimationFrame(tick);
        }
        animId = requestAnimationFrame(tick);
    }

    function stop() {
        if (animId !== null) { cancelAnimationFrame(animId); animId = null; }
        running = false;
        pills.length = 0;
        dragPill = null;
        ctx.clearRect(0, 0, W, H);
    }

    let resizeTimer: number;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
            if (running) resize();
        }, 100);
    });

    // Watch reveal visibility to start/stop
    const revealSibling = pit.parentElement?.querySelector('.reveal') ||
                          pit.nextElementSibling?.querySelector('.reveal');
    if (revealSibling) {
        const mo = new MutationObserver(() => {
            if (revealSibling.classList.contains('visible')) {
                if (!running) start();
            } else {
                if (running) stop();
            }
        });
        mo.observe(revealSibling, { attributes: true, attributeFilter: ['class'] });
        if (revealSibling.classList.contains('visible')) start();
    }
})();
</script>
