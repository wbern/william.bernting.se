---
import { useTranslations } from "../i18n/utils";
import { defaultLang, type Lang } from "../i18n/ui";

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const skills = [
    { label: "Agentic AI", featured: true },
    { label: "Test-Driven Development", featured: true },
    { label: "Claude / LLMs", featured: true },
    { label: "Node.js", featured: false },
    { label: "TypeScript", featured: false },
    { label: "React", featured: false },
    { label: "Next.js", featured: false },
    { label: "C#", featured: false },
    { label: "Vue", featured: false },
    { label: "Angular", featured: false },
    { label: "DevOps / CI/CD", featured: false },
    { label: "AWS / Azure", featured: false },
    { label: "Project Delivery", featured: false },
    { label: "Monorepos", featured: false },
    { label: "Micro-frontends", featured: false },
    { label: "Coaching", featured: false },
    { label: "Spec-kit", featured: false },
];
---

{/* Canvas fills the entire slide; heading floats on top */}
<div class="skills-pit" data-skills={JSON.stringify(skills)}>
    <canvas class="skills-canvas"></canvas>
</div>
<div class="section-inner skills-heading-overlay" style="text-align: center;">
    <div class="section-label reveal">{t("skills.label")}</div>
    <h2 class="section-heading reveal reveal-delay-1">
        {t("skills.heading.before")}<span class="highlight">{t("skills.heading.highlight")}</span>{t("skills.heading.after")}
    </h2>
</div>

<!-- Print fallback -->
<div class="skills-print-fallback">
    <div class="section-inner" style="text-align: center;">
        <div class="section-label">{t("skills.label")}</div>
        <h2 class="section-heading">{t("skills.heading.before")}<span class="highlight">{t("skills.heading.highlight")}</span>{t("skills.heading.after")}</h2>
        <div class="skills-cloud-print">
            {skills.map(s => (
                <span class:list={["skill-pill-print", { featured: s.featured }]}>{s.label}</span>
            ))}
        </div>
    </div>
</div>

<style>
    /* Canvas covers the entire slide */
    .skills-pit {
        position: absolute;
        inset: 0;
        overflow: hidden;
        z-index: 0;
    }

    .skills-canvas {
        width: 100%;
        height: 100%;
        display: block;
        cursor: default;
    }

    .skills-canvas.hovering-drop {
        cursor: pointer;
    }

    .skills-canvas.grabbing {
        cursor: grabbing;
    }

    .skills-canvas.grab {
        cursor: grab;
    }

    /* Heading floats at top of slide, pointer-events pass through to canvas */
    .skills-heading-overlay {
        position: absolute;
        top: 60px;
        left: 40px;
        right: 40px;
        z-index: 1;
        pointer-events: none;
    }

    @media (max-width: 600px) {
        .skills-heading-overlay {
            top: 40px;
            left: 20px;
            right: 20px;
        }
    }

    /* Print */
    .skills-print-fallback { display: none; }
    @media print {
        .skills-pit { display: none !important; }
        .skills-heading-overlay { display: none !important; }
        .skills-print-fallback { display: block !important; }
        .skills-cloud-print {
            display: flex; flex-wrap: wrap; gap: 3px; justify-content: center;
        }
        .skill-pill-print {
            font-family: var(--mono); font-size: 8px; padding: 2px 6px;
            border-radius: 100px; border: 1px solid var(--border);
            color: var(--text-dim);
        }
        .skill-pill-print.featured {
            border-color: var(--purple-dim); color: var(--purple);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .skills-canvas { display: none; }
        .skills-heading-overlay { display: none; }
        .skills-print-fallback {
            display: block !important;
        }
        .skills-cloud-print {
            display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;
        }
        .skill-pill-print {
            font-family: var(--mono); font-size: 14px; padding: 8px 18px;
            border-radius: 100px; border: 1px solid var(--border);
            background: var(--bg-card); color: var(--text-dim);
        }
        .skill-pill-print.featured {
            border-color: var(--purple-dim); color: var(--purple);
            background: var(--purple-glow);
        }
    }
</style>

<script>
(function () {
    const pit = document.querySelector<HTMLElement>('.skills-pit');
    if (!pit) return;
    const canvas = pit.querySelector<HTMLCanvasElement>('.skills-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;

    const skillsData: { label: string; featured: boolean }[] =
        JSON.parse(pit.dataset.skills || '[]');
    if (!skillsData.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // ─── Fruit tiers ───
    // Cherry, Strawberry, Grape, Orange, Apple, Pineapple, Watermelon
    interface TierDef {
        radius: number;
        stroke: string;
        glow: string;
        name: string;
        skills: string[];
    }

    const TIERS: TierDef[] = [
        { radius: 18, stroke: '#ff3366', glow: 'rgba(255,51,102,0.4)',
          name: 'cherry', skills: ['C#', 'Vue', 'Angular', 'Monorepos', 'Micro-frontends', 'Spec-kit'] },
        { radius: 24, stroke: '#ff6688', glow: 'rgba(255,102,136,0.4)',
          name: 'strawberry', skills: ['Node.js', 'React', 'Next.js'] },
        { radius: 32, stroke: '#aa66dd', glow: 'rgba(170,102,221,0.4)',
          name: 'grape', skills: ['TypeScript', 'DevOps / CI/CD'] },
        { radius: 40, stroke: '#ffaa22', glow: 'rgba(255,170,34,0.4)',
          name: 'orange', skills: ['AWS / Azure', 'Project Delivery', 'Coaching'] },
        { radius: 50, stroke: '#ff4444', glow: 'rgba(255,68,68,0.4)',
          name: 'apple', skills: ['Agentic AI', 'Claude / LLMs', 'Test-Driven Development'] },
        { radius: 62, stroke: '#ffdd44', glow: 'rgba(255,221,68,0.4)',
          name: 'pineapple', skills: ['Agentic AI', 'Claude / LLMs'] },
        { radius: 76, stroke: '#44dd66', glow: 'rgba(68,221,102,0.4)',
          name: 'watermelon', skills: ['Agentic AI', 'Test-Driven Development'] },
    ];

    const MAX_SPAWN_TIER = 4; // tiers 0-4 are spawnable

    // ─── Static skill-to-tier mapping ───
    // Each tier cycles through its skill pool
    const tierSpawnIdx: number[] = TIERS.map(() => 0);
    function skillForTier(tier: number): string {
        const pool = TIERS[tier].skills;
        const label = pool[tierSpawnIdx[tier] % pool.length];
        tierSpawnIdx[tier]++;
        return label;
    }

    // ─── Physics constants ───
    const GRAVITY   = 600;
    const BOUNCE    = 0.25;
    const AIR_DRAG  = 0.998;
    const DT_CAP    = 0.033;
    const MAX_FRUITS = 25;
    const MAX_SPEED = 800; // velocity cap to prevent tunneling
    const AUTO_DROP_INTERVAL = 2500;
    const IDLE_TIMEOUT = 8000;
    const MERGE_DURATION = 150;
    const FONT_SM   = '600 11px "JetBrains Mono", monospace';
    const FONT_MD   = '600 13px "JetBrains Mono", monospace';
    const FONT_LG   = '600 16px "JetBrains Mono", monospace';
    const BOWL_STROKE = '#9b4dca';
    const BOWL_GLOW  = 'rgba(155, 77, 202, 0.35)';

    // ─── Fruit interface ───
    interface Fruit {
        x: number; y: number;
        vx: number; vy: number;
        radius: number;
        tier: number;
        label: string;
        alive: boolean;
        opacity: number;
        merging: boolean;
        mergeTarget: { x: number; y: number } | null;
        mergeTimer: number;
        scaleAnim: number; // 1.0 = normal, >1 = pop-in
        mass: number;
        age: number;
        grabbed: boolean;
        // For tier 6 fade-out
        maxLifetime: number;
        lifetime: number;
    }

    // ─── Merge particles ───
    interface Particle {
        x: number; y: number;
        vx: number; vy: number;
        life: number;
        maxLife: number;
        color: string;
        size: number;
    }

    // ─── Bowl geometry ───
    interface Bowl {
        x: number; y: number; // top-left of bowl bounding rect
        w: number; h: number;
        cx: number;           // center x
        wallThickness: number;
        cornerRadius: number;
        // Wall segments for collision (inner edges)
        leftWall:  { x1: number; y1: number; x2: number; y2: number };
        rightWall: { x1: number; y1: number; x2: number; y2: number };
        bottomWall: { x1: number; y1: number; x2: number; y2: number };
        bottom:    number; // y of inner bottom
        dropZoneTop: number; // y above which is the "drop zone"
    }

    const fruits: Fruit[] = [];
    const particles: Particle[] = [];
    let bowl: Bowl = {} as Bowl;
    let animId: number | null = null;
    let running = false;
    let W = 0, H = 0;
    let ageCounter = 0;

    // ─── Auto-pilot state ───
    let lastAutoDrop = 0;
    let userControlActive = false;
    let lastUserAction = 0;

    // ─── Drop preview ───
    let previewX: number | null = null;
    let previewTier: number = 0;
    let previewLabel: string = '';
    let nextDropReady = true;

    // ─── Drag state ───
    let dragFruit: Fruit | null = null;
    let dragOffX = 0, dragOffY = 0;
    let prevMouseX = 0, prevMouseY = 0;
    let mouseVX = 0, mouseVY = 0;

    // randomSkillLabel no longer used — skills are assigned per-tier via skillForTier()

    function fontForTier(tier: number): string {
        if (tier <= 1) return FONT_SM;
        if (tier <= 3) return FONT_MD;
        return FONT_LG;
    }

    function resize() {
        const dpr = window.devicePixelRatio || 1;
        W = pit.offsetWidth;
        H = pit.offsetHeight;
        canvas.width = W * dpr;
        canvas.height = H * dpr;
        canvas.style.width = W + 'px';
        canvas.style.height = H + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

        // Compute bowl geometry — taller and higher on desktop
        const bw = Math.min(480, W - 80);
        const bh = Math.min(460, H * 0.62);
        const bx = (W - bw) / 2;
        const by = H - bh - 60; // more breathing room from bottom
        const wallT = 4;
        const corner = 20;

        // Slight taper: top is wider, bottom is narrower
        const taperInset = 15;

        bowl = {
            x: bx, y: by, w: bw, h: bh,
            cx: W / 2,
            wallThickness: wallT,
            cornerRadius: corner,
            leftWall: {
                x1: bx + taperInset, y1: by + bh - corner,
                x2: bx, y2: by
            },
            rightWall: {
                x1: bx + bw - taperInset, y1: by + bh - corner,
                x2: bx + bw, y2: by
            },
            bottomWall: {
                x1: bx + taperInset, y1: by + bh - corner,
                x2: bx + bw - taperInset, y2: by + bh - corner
            },
            bottom: by + bh - corner,
            dropZoneTop: by - 60,
        };
    }

    // ─── Create a fruit ───
    function createFruit(x: number, y: number, tier: number, label: string, scaleAnim: number = 1.0): Fruit {
        const t = TIERS[tier];
        ageCounter++;
        return {
            x, y, vx: 0, vy: 0,
            radius: t.radius,
            tier,
            label,
            alive: true,
            opacity: 1,
            merging: false,
            mergeTarget: null,
            mergeTimer: 0,
            scaleAnim,
            mass: t.radius * t.radius, // mass proportional to area
            age: ageCounter,
            grabbed: false,
            maxLifetime: tier === 6 ? 8000 : 0, // tier 6 fades after 8s
            lifetime: 0,
        };
    }

    // ─── Auto-drop a fruit into the bowl ───
    function autoDropFruit() {
        const aliveCount = fruits.filter(f => f.alive && !f.merging).length;
        if (aliveCount >= MAX_FRUITS) return;
        const tier = Math.floor(Math.random() * (MAX_SPAWN_TIER + 1));
        const label = skillForTier(tier);
        const margin = TIERS[tier].radius + 20;
        const dropX = bowl.x + margin + Math.random() * (bowl.w - margin * 2);
        const f = createFruit(dropX, bowl.y - TIERS[tier].radius - 10, tier, label);
        f.vy = 20;
        fruits.push(f);
    }

    // ─── User drop a fruit ───
    function userDropFruit(x: number) {
        const aliveCount = fruits.filter(f => f.alive && !f.merging).length;
        if (aliveCount >= MAX_FRUITS) return;
        const tier = previewTier;
        const label = previewLabel;
        const clampedX = Math.max(bowl.x + TIERS[tier].radius + 5,
                                   Math.min(bowl.x + bowl.w - TIERS[tier].radius - 5, x));
        const f = createFruit(clampedX, bowl.y - TIERS[tier].radius - 5, tier, label);
        f.vy = 10;
        fruits.push(f);
        prepareNextDrop();
    }

    function prepareNextDrop() {
        previewTier = Math.floor(Math.random() * (MAX_SPAWN_TIER + 1));
        previewLabel = skillForTier(previewTier);
        nextDropReady = true;
    }

    // ─── Spawn merge particles ───
    function spawnParticles(x: number, y: number, color: string) {
        const count = 6 + Math.floor(Math.random() * 3);
        for (let i = 0; i < count; i++) {
            const angle = (Math.PI * 2 / count) * i + (Math.random() - 0.5) * 0.5;
            const speed = 80 + Math.random() * 120;
            particles.push({
                x, y,
                vx: Math.cos(angle) * speed,
                vy: Math.sin(angle) * speed,
                life: 1,
                maxLife: 0.4 + Math.random() * 0.3,
                color,
                size: 2 + Math.random() * 3,
            });
        }
    }

    // ─── Circle-line-segment collision ───
    function circleLineCollision(
        cx: number, cy: number, r: number,
        x1: number, y1: number, x2: number, y2: number
    ): { nx: number; ny: number; depth: number } | null {
        const dx = x2 - x1, dy = y2 - y1;
        const len2 = dx * dx + dy * dy;
        if (len2 === 0) return null;
        let t = ((cx - x1) * dx + (cy - y1) * dy) / len2;
        t = Math.max(0, Math.min(1, t));
        const closestX = x1 + t * dx;
        const closestY = y1 + t * dy;
        const distX = cx - closestX;
        const distY = cy - closestY;
        const dist = Math.sqrt(distX * distX + distY * distY);
        if (dist < r) {
            const nx = dist > 0 ? distX / dist : 0;
            const ny = dist > 0 ? distY / dist : -1;
            return { nx, ny, depth: r - dist };
        }
        return null;
    }

    // ─── Hit-test: find fruit under cursor ───
    function hitTest(mx: number, my: number): Fruit | null {
        for (let i = fruits.length - 1; i >= 0; i--) {
            const f = fruits[i];
            if (!f.alive || f.merging || f.opacity < 0.5) continue;
            const dx = mx - f.x, dy = my - f.y;
            if (dx * dx + dy * dy <= f.radius * f.radius) return f;
        }
        return null;
    }

    function isInDropZone(my: number): boolean {
        return my < bowl.y && my > bowl.dropZoneTop;
    }

    function isInBowlArea(mx: number, my: number): boolean {
        return mx >= bowl.x - 20 && mx <= bowl.x + bowl.w + 20 &&
               my >= bowl.dropZoneTop && my <= bowl.y + bowl.h + 20;
    }

    // ─── Canvas position helper ───
    function getCanvasPos(e: MouseEvent | Touch): { x: number; y: number } {
        const rect = canvas.getBoundingClientRect();
        return { x: e.clientX - rect.left, y: e.clientY - rect.top };
    }

    // ─── Pointer handlers ───
    let touchDropPending = false; // touch-only: preview before drop

    function onPointerDown(mx: number, my: number, isTouch = false) {
        // Check if clicking a fruit in the bowl first
        const hit = hitTest(mx, my);
        if (hit) {
            dragFruit = hit;
            hit.grabbed = true;
            dragOffX = mx - hit.x;
            dragOffY = my - hit.y;
            prevMouseX = mx;
            prevMouseY = my;
            mouseVX = 0;
            mouseVY = 0;
            userControlActive = true;
            lastUserAction = performance.now();
            return true;
        }
        // Check if clicking in drop zone to release a fruit
        if (isInDropZone(my) && mx >= bowl.x && mx <= bowl.x + bowl.w && nextDropReady) {
            userControlActive = true;
            lastUserAction = performance.now();
            if (isTouch) {
                // Touch: show preview, drop on release
                touchDropPending = true;
                previewX = mx;
            } else {
                // Mouse: drop immediately (click)
                userDropFruit(mx);
            }
            return true;
        }
        return false;
    }

    function onPointerMove(mx: number, my: number) {
        if (dragFruit) {
            mouseVX = (mx - prevMouseX) * 60;
            mouseVY = (my - prevMouseY) * 60;
            prevMouseX = mx;
            prevMouseY = my;
            dragFruit.x = mx - dragOffX;
            dragFruit.y = my - dragOffY;
            dragFruit.vx = 0;
            dragFruit.vy = 0;
            return;
        }
        // Update drop preview position
        if (isInDropZone(my) && mx >= bowl.x && mx <= bowl.x + bowl.w) {
            previewX = mx;
            userControlActive = true;
            lastUserAction = performance.now();
        } else if (isInBowlArea(mx, my)) {
            // Keep preview visible when hovering near bowl
            previewX = Math.max(bowl.x + TIERS[previewTier].radius + 5,
                               Math.min(bowl.x + bowl.w - TIERS[previewTier].radius - 5, mx));
            userControlActive = true;
            lastUserAction = performance.now();
        } else {
            previewX = null;
        }
    }

    function onPointerUp() {
        if (touchDropPending) {
            touchDropPending = false;
            if (previewX !== null && nextDropReady) {
                userDropFruit(previewX);
            }
            previewX = null;
            return;
        }
        if (!dragFruit) return;
        dragFruit.vx = mouseVX;
        dragFruit.vy = mouseVY;
        dragFruit.grabbed = false;
        dragFruit = null;
    }

    function onPointerLeave() {
        previewX = null;
        touchDropPending = false;
        if (dragFruit) {
            dragFruit.vx = mouseVX;
            dragFruit.vy = mouseVY;
            dragFruit.grabbed = false;
            dragFruit = null;
        }
    }

    // Mouse events
    canvas.addEventListener('mousedown', (e) => {
        const pos = getCanvasPos(e);
        if (onPointerDown(pos.x, pos.y)) {
            e.stopPropagation();
        }
    });
    canvas.addEventListener('mousemove', (e) => {
        const pos = getCanvasPos(e);
        onPointerMove(pos.x, pos.y);
        if (dragFruit) {
            e.stopPropagation();
            canvas.classList.add('grabbing');
            canvas.classList.remove('grab', 'hovering-drop');
        } else if (isInDropZone(pos.y) && pos.x >= bowl.x && pos.x <= bowl.x + bowl.w) {
            canvas.classList.add('hovering-drop');
            canvas.classList.remove('grab', 'grabbing');
        } else if (hitTest(pos.x, pos.y)) {
            canvas.classList.add('grab');
            canvas.classList.remove('hovering-drop', 'grabbing');
        } else {
            canvas.classList.remove('grab', 'hovering-drop', 'grabbing');
        }
    });
    canvas.addEventListener('mouseup', (e) => {
        if (dragFruit) e.stopPropagation();
        onPointerUp();
        canvas.classList.remove('grabbing');
    });
    canvas.addEventListener('mouseleave', () => {
        onPointerLeave();
        canvas.classList.remove('grab', 'hovering-drop', 'grabbing');
    });

    // Touch events
    canvas.addEventListener('touchstart', (e) => {
        if (e.touches.length !== 1) return;
        const pos = getCanvasPos(e.touches[0]);
        if (onPointerDown(pos.x, pos.y, true)) {
            e.preventDefault();
            e.stopPropagation();
        }
    }, { passive: false });
    canvas.addEventListener('touchmove', (e) => {
        if (!dragFruit && !touchDropPending) return;
        e.preventDefault();
        e.stopPropagation();
        const pos = getCanvasPos(e.touches[0]);
        if (touchDropPending) {
            // Update preview position as finger moves
            previewX = Math.max(bowl.x + TIERS[previewTier].radius + 5,
                               Math.min(bowl.x + bowl.w - TIERS[previewTier].radius - 5, pos.x));
        } else {
            onPointerMove(pos.x, pos.y);
        }
    }, { passive: false });
    canvas.addEventListener('touchend', (e) => {
        if (dragFruit || touchDropPending) e.stopPropagation();
        onPointerUp();
    });
    canvas.addEventListener('touchcancel', () => {
        onPointerLeave();
    });

    // ─── Physics step ───
    function step(dt: number) {
        // Update particles
        for (let i = particles.length - 1; i >= 0; i--) {
            const p = particles[i];
            p.x += p.vx * dt;
            p.y += p.vy * dt;
            p.vy += 200 * dt; // gravity on particles
            p.life -= dt / p.maxLife;
            if (p.life <= 0) particles.splice(i, 1);
        }

        // Update merging fruits
        for (const f of fruits) {
            if (!f.alive) continue;
            if (f.merging && f.mergeTarget) {
                f.mergeTimer += dt * 1000;
                const t = Math.min(f.mergeTimer / MERGE_DURATION, 1);
                f.x += (f.mergeTarget.x - f.x) * t * 0.3;
                f.y += (f.mergeTarget.y - f.y) * t * 0.3;
                f.scaleAnim = 1 - t * 0.8;
                if (f.mergeTimer >= MERGE_DURATION) {
                    f.alive = false;
                }
                continue;
            }
            // Scale pop animation
            if (f.scaleAnim > 1.01) {
                f.scaleAnim += (1 - f.scaleAnim) * 8 * dt;
                if (f.scaleAnim < 1.01) f.scaleAnim = 1;
            }
            // Tier 6 lifetime fade
            if (f.maxLifetime > 0) {
                f.lifetime += dt * 1000;
                if (f.lifetime > f.maxLifetime * 0.7) {
                    f.opacity = Math.max(0, 1 - (f.lifetime - f.maxLifetime * 0.7) / (f.maxLifetime * 0.3));
                    if (f.opacity <= 0) f.alive = false;
                }
            }
            // Fade dying
            if (f.opacity < 1 && f.maxLifetime === 0) {
                f.opacity -= 1.5 * dt;
                if (f.opacity <= 0) f.alive = false;
            }
        }

        // ─── Clamp velocity to prevent tunneling ───
        function clampVelocity(f: Fruit) {
            const speed = Math.sqrt(f.vx * f.vx + f.vy * f.vy);
            if (speed > MAX_SPEED) {
                const scale = MAX_SPEED / speed;
                f.vx *= scale;
                f.vy *= scale;
            }
        }

        // ─── Resolve bowl wall collisions for a single fruit ───
        function resolveBowlCollision(f: Fruit) {
            // Left wall
            const lw = bowl.leftWall;
            const lhit = circleLineCollision(f.x, f.y, f.radius, lw.x1, lw.y1, lw.x2, lw.y2);
            if (lhit) {
                f.x += lhit.nx * lhit.depth;
                f.y += lhit.ny * lhit.depth;
                const vDotN = f.vx * lhit.nx + f.vy * lhit.ny;
                if (vDotN < 0) {
                    f.vx -= (1 + BOUNCE) * vDotN * lhit.nx;
                    f.vy -= (1 + BOUNCE) * vDotN * lhit.ny;
                }
            }

            // Right wall
            const rw = bowl.rightWall;
            const rhit = circleLineCollision(f.x, f.y, f.radius, rw.x1, rw.y1, rw.x2, rw.y2);
            if (rhit) {
                f.x += rhit.nx * rhit.depth;
                f.y += rhit.ny * rhit.depth;
                const vDotN = f.vx * rhit.nx + f.vy * rhit.ny;
                if (vDotN < 0) {
                    f.vx -= (1 + BOUNCE) * vDotN * rhit.nx;
                    f.vy -= (1 + BOUNCE) * vDotN * rhit.ny;
                }
            }

            // Bottom wall (line segment across bottom)
            const bw = bowl.bottomWall;
            const bhit = circleLineCollision(f.x, f.y, f.radius, bw.x1, bw.y1, bw.x2, bw.y2);
            if (bhit) {
                f.x += bhit.nx * bhit.depth;
                f.y += bhit.ny * bhit.depth;
                const vDotN = f.vx * bhit.nx + f.vy * bhit.ny;
                if (vDotN < 0) {
                    f.vx -= (1 + BOUNCE) * vDotN * bhit.nx;
                    f.vy -= (1 + BOUNCE) * vDotN * bhit.ny;
                }
                f.vx *= 0.9; // friction on bottom
            }

            // Hard bottom clamp (safety)
            const bottomY = bowl.bottom;
            if (f.y + f.radius > bottomY) {
                f.y = bottomY - f.radius;
                if (f.vy > 0) f.vy = -f.vy * BOUNCE;
                f.vx *= 0.9;
            }

            // Keep in canvas bounds (safety — kill if way out)
            if (f.x - f.radius < -100 || f.x + f.radius > W + 100 || f.y + f.radius > H + 100) {
                f.alive = false;
                return;
            }
            if (f.x - f.radius < 0) { f.x = f.radius; f.vx = Math.abs(f.vx) * BOUNCE; }
            if (f.x + f.radius > W) { f.x = W - f.radius; f.vx = -Math.abs(f.vx) * BOUNCE; }
            if (f.y + f.radius > H) { f.y = H - f.radius; f.vy = -Math.abs(f.vy) * BOUNCE; }
        }

        // Physics for non-merging alive fruits
        for (const f of fruits) {
            if (!f.alive || f.merging || f.grabbed) continue;

            f.vy += GRAVITY * dt;
            f.vx *= AIR_DRAG;
            f.vy *= AIR_DRAG;
            clampVelocity(f);

            f.x += f.vx * dt;
            f.y += f.vy * dt;

            resolveBowlCollision(f);
        }

        // Fruit-fruit collisions with merge detection
        for (let iter = 0; iter < 3; iter++) {
            for (let i = 0; i < fruits.length; i++) {
                const a = fruits[i];
                if (!a.alive || a.merging) continue;
                for (let j = i + 1; j < fruits.length; j++) {
                    const b = fruits[j];
                    if (!b.alive || b.merging) continue;

                    const dx = b.x - a.x;
                    const dy = b.y - a.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    const minDist = a.radius + b.radius;

                    if (dist >= minDist) continue;

                    const overlap = minDist - dist;
                    const nx = dist > 0 ? dx / dist : 0;
                    const ny = dist > 0 ? dy / dist : -1;

                    // Check for merge on first iteration
                    if (iter === 0 && a.tier === b.tier && a.tier < 6 &&
                        !a.grabbed && !b.grabbed) {
                        // Trigger merge!
                        const midX = (a.x + b.x) / 2;
                        const midY = (a.y + b.y) / 2;
                        a.merging = true;
                        b.merging = true;
                        a.mergeTarget = { x: midX, y: midY };
                        b.mergeTarget = { x: midX, y: midY };
                        a.mergeTimer = 0;
                        b.mergeTimer = 0;

                        // Schedule spawn of merged fruit
                        const newTier = a.tier + 1;
                        const newLabel = skillForTier(newTier);
                        const strokeColor = TIERS[newTier].stroke;

                        setTimeout(() => {
                            const nf = createFruit(midX, midY, newTier, newLabel, 1.8);
                            nf.vy = -30; // slight upward pop
                            fruits.push(nf);
                            spawnParticles(midX, midY, strokeColor);
                        }, MERGE_DURATION);

                        continue; // skip normal collision
                    }

                    // Positional correction
                    if (a.grabbed) {
                        b.x += nx * overlap;
                        b.y += ny * overlap;
                    } else if (b.grabbed) {
                        a.x -= nx * overlap;
                        a.y -= ny * overlap;
                    } else {
                        const totalMass = a.mass + b.mass;
                        const aRatio = b.mass / totalMass;
                        const bRatio = a.mass / totalMass;
                        a.x -= nx * overlap * aRatio;
                        a.y -= ny * overlap * aRatio;
                        b.x += nx * overlap * bRatio;
                        b.y += ny * overlap * bRatio;
                    }

                    // Impulse-based velocity response (first iteration only)
                    if (iter === 0) {
                        if (a.grabbed || b.grabbed) {
                            const other = a.grabbed ? b : a;
                            const sign = a.grabbed ? 1 : -1;
                            other.vx += nx * sign * 150;
                            other.vy += ny * sign * 150;
                        } else {
                            const dvx = a.vx - b.vx;
                            const dvy = a.vy - b.vy;
                            const dvDotN = dvx * nx + dvy * ny;
                            if (dvDotN > 0) {
                                const totalMass = a.mass + b.mass;
                                const impulse = (1 + BOUNCE) * dvDotN / totalMass;
                                a.vx -= impulse * b.mass * nx;
                                a.vy -= impulse * b.mass * ny;
                                b.vx += impulse * a.mass * nx;
                                b.vy += impulse * a.mass * ny;
                            }
                        }
                    }
                }
            }
        }

        // Second pass: re-check bowl collisions after fruit-fruit resolution
        // Prevents fruits pushed through walls by overlap correction
        for (const f of fruits) {
            if (!f.alive || f.merging || f.grabbed) continue;
            clampVelocity(f);
            resolveBowlCollision(f);
        }
    }

    // ─── Draw bowl ───
    function drawBowl() {
        ctx.save();

        const { x, y, w, h, cornerRadius: cr } = bowl;
        const taperInset = 15;

        // Glow
        ctx.shadowColor = BOWL_GLOW;
        ctx.shadowBlur = 20;
        ctx.strokeStyle = BOWL_STROKE;
        ctx.lineWidth = 3;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';

        ctx.beginPath();
        // Left wall top (wider) to bottom (narrower)
        ctx.moveTo(x, y);
        ctx.lineTo(x + taperInset, y + h - cr);
        // Bottom-left corner
        ctx.quadraticCurveTo(x + taperInset, y + h, x + taperInset + cr, y + h);
        // Bottom
        ctx.lineTo(x + w - taperInset - cr, y + h);
        // Bottom-right corner
        ctx.quadraticCurveTo(x + w - taperInset, y + h, x + w - taperInset, y + h - cr);
        // Right wall bottom to top
        ctx.lineTo(x + w, y);

        ctx.stroke();
        ctx.restore();
    }

    // ─── Draw fruit shapes — Suika-style round circles ───
    function drawCherry(x: number, y: number, r: number) {
        // Cherry: solid round red ball with stem + tiny leaf
        const grad = ctx.createRadialGradient(x - r * 0.3, y - r * 0.3, r * 0.1, x, y, r);
        grad.addColorStop(0, '#ff6666');
        grad.addColorStop(0.5, '#dd1133');
        grad.addColorStop(1, '#880011');
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
        // Stem
        ctx.strokeStyle = '#3a6622';
        ctx.lineWidth = Math.max(1.5, r * 0.07);
        ctx.lineCap = 'round';
        ctx.beginPath();
        ctx.moveTo(x, y - r * 0.85);
        ctx.quadraticCurveTo(x + r * 0.15, y - r * 1.15, x + r * 0.1, y - r * 1.05);
        ctx.stroke();
        // Tiny leaf
        ctx.beginPath();
        ctx.ellipse(x + r * 0.18, y - r * 0.95, r * 0.15, r * 0.06, 0.4, 0, Math.PI * 2);
        ctx.fillStyle = '#44aa44';
        ctx.fill();
        // Highlight
        ctx.beginPath();
        ctx.arc(x - r * 0.25, y - r * 0.3, r * 0.2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.3)';
        ctx.fill();
    }

    function drawStrawberry(x: number, y: number, r: number) {
        // Strawberry: round red/pink ball with yellow seed dots + green cap
        const grad = ctx.createRadialGradient(x - r * 0.2, y - r * 0.2, r * 0.1, x, y, r);
        grad.addColorStop(0, '#ff7788');
        grad.addColorStop(0.5, '#ee2244');
        grad.addColorStop(1, '#aa1133');
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
        // Seeds — tiny yellow dots scattered on surface
        ctx.save();
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.clip();
        ctx.fillStyle = '#ffdd66';
        const seedPositions = [
            [-0.35, -0.3], [0.3, -0.35], [-0.5, 0.05], [0.45, 0.1],
            [-0.15, 0.1], [0.15, -0.1], [-0.3, 0.4], [0.35, 0.35],
            [0.0, 0.5], [0.0, -0.5], [-0.5, -0.15], [0.5, -0.1],
        ];
        for (const [sx, sy] of seedPositions) {
            ctx.beginPath();
            ctx.arc(x + r * sx, y + r * sy, r * 0.04, 0, Math.PI * 2);
            ctx.fill();
        }
        ctx.restore();
        // Green cap at top — small spiky leaves
        ctx.fillStyle = '#33aa44';
        for (let i = 0; i < 5; i++) {
            const angle = -Math.PI / 2 + (i - 2) * 0.4;
            ctx.beginPath();
            ctx.ellipse(
                x + Math.cos(angle) * r * 0.1,
                y - r * 0.85 + Math.sin(angle) * r * 0.05,
                r * 0.2, r * 0.07,
                angle + Math.PI / 2, 0, Math.PI * 2
            );
            ctx.fill();
        }
        // Highlight
        ctx.beginPath();
        ctx.arc(x - r * 0.25, y - r * 0.3, r * 0.18, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.22)';
        ctx.fill();
    }

    function drawGrape(x: number, y: number, r: number) {
        // Grape: round purple ball with subtle shine + tiny stem
        const grad = ctx.createRadialGradient(x - r * 0.3, y - r * 0.3, r * 0.05, x, y, r);
        grad.addColorStop(0, '#cc88ff');
        grad.addColorStop(0.4, '#8844cc');
        grad.addColorStop(1, '#441166');
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
        // Stem
        ctx.strokeStyle = '#5a3a1a';
        ctx.lineWidth = Math.max(1.5, r * 0.06);
        ctx.lineCap = 'round';
        ctx.beginPath();
        ctx.moveTo(x, y - r * 0.9);
        ctx.lineTo(x + r * 0.05, y - r * 1.1);
        ctx.stroke();
        // Highlight — glossy reflection
        ctx.beginPath();
        ctx.ellipse(x - r * 0.25, y - r * 0.3, r * 0.15, r * 0.25, -0.3, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.25)';
        ctx.fill();
        // Secondary small highlight
        ctx.beginPath();
        ctx.arc(x - r * 0.15, y - r * 0.45, r * 0.08, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.15)';
        ctx.fill();
    }

    function drawOrange(x: number, y: number, r: number) {
        // Orange: round, textured peel, small navel at bottom, leaf on top
        const grad = ctx.createRadialGradient(x - r * 0.25, y - r * 0.25, r * 0.1, x, y, r);
        grad.addColorStop(0, '#ffcc44');
        grad.addColorStop(0.4, '#ff9900');
        grad.addColorStop(1, '#cc6600');
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
        // Peel texture — subtle bumpy dots
        ctx.save();
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.clip();
        ctx.globalAlpha *= 0.12;
        for (let i = 0; i < 30; i++) {
            const angle = (Math.PI * 2 / 30) * i + (i % 2) * 0.1;
            const dist = r * (0.2 + (i % 3) * 0.25);
            ctx.beginPath();
            ctx.arc(x + Math.cos(angle) * dist, y + Math.sin(angle) * dist, r * 0.04, 0, Math.PI * 2);
            ctx.fillStyle = '#ffeecc';
            ctx.fill();
        }
        ctx.restore();
        // Navel at bottom
        ctx.beginPath();
        ctx.arc(x, y + r * 0.7, r * 0.1, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(180,100,0,0.3)';
        ctx.fill();
        // Small leaf + stem at top (kept within circle area)
        ctx.strokeStyle = '#3a6622';
        ctx.lineWidth = Math.max(1.5, r * 0.06);
        ctx.beginPath();
        ctx.moveTo(x, y - r * 0.85);
        ctx.lineTo(x, y - r * 0.95);
        ctx.stroke();
        ctx.beginPath();
        ctx.ellipse(x + r * 0.1, y - r * 0.9, r * 0.12, r * 0.06, 0.4, 0, Math.PI * 2);
        ctx.fillStyle = '#44aa44';
        ctx.fill();
        // Highlight
        ctx.beginPath();
        ctx.arc(x - r * 0.25, y - r * 0.3, r * 0.2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.18)';
        ctx.fill();
    }

    function drawApple(x: number, y: number, r: number) {
        // Apple: round red ball with top indent shadow, small stem + leaf inside circle
        const grad = ctx.createRadialGradient(x - r * 0.3, y - r * 0.2, r * 0.1, x, y + r * 0.1, r);
        grad.addColorStop(0, '#ff6666');
        grad.addColorStop(0.4, '#dd2233');
        grad.addColorStop(0.8, '#aa1122');
        grad.addColorStop(1, '#771111');
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
        // Top indent (darker shadow)
        ctx.save();
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.clip();
        ctx.beginPath();
        ctx.ellipse(x, y - r * 0.8, r * 0.35, r * 0.2, 0, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(0,0,0,0.25)';
        ctx.fill();
        // Bottom bump
        ctx.beginPath();
        ctx.ellipse(x, y + r * 0.85, r * 0.2, r * 0.1, 0, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(0,0,0,0.1)';
        ctx.fill();
        ctx.restore();
        // Stem (short, inside circle)
        ctx.strokeStyle = '#5a3a1a';
        ctx.lineWidth = Math.max(2, r * 0.05);
        ctx.lineCap = 'round';
        ctx.beginPath();
        ctx.moveTo(x, y - r * 0.8);
        ctx.lineTo(x + r * 0.03, y - r * 0.92);
        ctx.stroke();
        // Leaf (small, inside circle)
        ctx.beginPath();
        ctx.moveTo(x + r * 0.05, y - r * 0.85);
        ctx.quadraticCurveTo(x + r * 0.3, y - r * 0.98, x + r * 0.25, y - r * 0.78);
        ctx.quadraticCurveTo(x + r * 0.15, y - r * 0.85, x + r * 0.05, y - r * 0.85);
        ctx.fillStyle = '#33aa33';
        ctx.fill();
        // Highlight
        ctx.beginPath();
        ctx.ellipse(x - r * 0.3, y - r * 0.2, r * 0.15, r * 0.25, -0.3, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.2)';
        ctx.fill();
    }

    function drawPineapple(x: number, y: number, r: number) {
        // Pineapple: round golden ball with crosshatch pattern, green crown inside circle
        const grad = ctx.createRadialGradient(x - r * 0.15, y - r * 0.1, r * 0.2, x, y, r);
        grad.addColorStop(0, '#ffdd55');
        grad.addColorStop(0.5, '#ddaa22');
        grad.addColorStop(1, '#aa7711');
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
        // Diamond crosshatch pattern
        ctx.save();
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.clip();
        ctx.strokeStyle = 'rgba(150,90,10,0.3)';
        ctx.lineWidth = 1;
        for (let i = -6; i <= 6; i++) {
            ctx.beginPath();
            ctx.moveTo(x + i * r * 0.25 - r, y - r);
            ctx.lineTo(x + i * r * 0.25 + r, y + r * 1.2);
            ctx.stroke();
        }
        for (let i = -6; i <= 6; i++) {
            ctx.beginPath();
            ctx.moveTo(x + i * r * 0.25 + r, y - r);
            ctx.lineTo(x + i * r * 0.25 - r, y + r * 1.2);
            ctx.stroke();
        }
        ctx.restore();
        // Crown — small green leaves at top, kept inside circle
        const crownLeaves = 5;
        for (let i = 0; i < crownLeaves; i++) {
            const angle = -Math.PI / 2 + (i - (crownLeaves - 1) / 2) * 0.25;
            const leafLen = r * (0.35 + (i % 2) * 0.1);
            ctx.beginPath();
            ctx.moveTo(x + Math.cos(angle + 0.06) * r * 0.1, y - r * 0.85);
            ctx.quadraticCurveTo(
                x + Math.cos(angle) * leafLen * 0.5,
                y - r * 0.85 + Math.sin(angle) * leafLen * 0.5,
                x + Math.cos(angle) * leafLen,
                y - r * 0.85 + Math.sin(angle) * leafLen
            );
            ctx.quadraticCurveTo(
                x + Math.cos(angle) * leafLen * 0.4,
                y - r * 0.85 + Math.sin(angle) * leafLen * 0.4 + r * 0.04,
                x + Math.cos(angle - 0.06) * r * 0.1,
                y - r * 0.85
            );
            ctx.fillStyle = i % 2 === 0 ? '#33aa33' : '#44bb44';
            ctx.fill();
        }
        // Highlight
        ctx.beginPath();
        ctx.arc(x - r * 0.2, y - r * 0.15, r * 0.15, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.15)';
        ctx.fill();
    }

    function drawWatermelon(x: number, y: number, r: number) {
        // Watermelon EXTERIOR: dark green base with lighter green stripes
        // Base — dark green
        const baseGrad = ctx.createRadialGradient(x - r * 0.2, y - r * 0.2, r * 0.1, x, y, r);
        baseGrad.addColorStop(0, '#3a8a4a');
        baseGrad.addColorStop(0.5, '#2a6e35');
        baseGrad.addColorStop(1, '#1a4a22');
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = baseGrad;
        ctx.fill();
        // Lighter green stripes curving from top to bottom
        ctx.save();
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.clip();
        ctx.strokeStyle = '#4aaa5a';
        ctx.lineWidth = r * 0.12;
        ctx.lineCap = 'round';
        const stripeCount = 8;
        for (let i = 0; i < stripeCount; i++) {
            const baseAngle = (Math.PI * 2 / stripeCount) * i;
            ctx.beginPath();
            ctx.moveTo(x, y - r * 0.15);
            // Curve outward from near-top toward bottom
            const cx1 = x + Math.cos(baseAngle) * r * 0.7;
            const cy1 = y + Math.sin(baseAngle) * r * 0.7;
            const ex = x + Math.cos(baseAngle) * r * 1.15;
            const ey = y + Math.sin(baseAngle) * r * 1.15;
            ctx.quadraticCurveTo(cx1, cy1, ex, ey);
            ctx.stroke();
        }
        ctx.restore();
        // Small stem dimple at top
        ctx.beginPath();
        ctx.arc(x, y - r * 0.85, r * 0.08, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(90,60,20,0.5)';
        ctx.fill();
        // Highlight
        ctx.beginPath();
        ctx.ellipse(x - r * 0.3, y - r * 0.25, r * 0.15, r * 0.22, -0.3, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.12)';
        ctx.fill();
    }

    function drawFruitShape(x: number, y: number, r: number, tier: number, alpha: number) {
        const t = TIERS[tier];
        ctx.save();
        ctx.globalAlpha = alpha;

        // Subtle glow behind fruit
        ctx.shadowColor = t.glow;
        ctx.shadowBlur = 12;

        // Draw the specific fruit
        if (tier === 0) drawCherry(x, y, r);
        else if (tier === 1) drawStrawberry(x, y, r);
        else if (tier === 2) drawGrape(x, y, r);
        else if (tier === 3) drawOrange(x, y, r);
        else if (tier === 4) drawApple(x, y, r);
        else if (tier === 5) drawPineapple(x, y, r);
        else if (tier === 6) drawWatermelon(x, y, r);

        ctx.shadowBlur = 0;
        ctx.restore();
    }

    // ─── Draw a fruit with label ───
    function drawFruit(f: Fruit) {
        ctx.save();
        ctx.globalAlpha = f.opacity;

        const r = f.radius * f.scaleAnim;

        // Draw the fruit shape
        drawFruitShape(f.x, f.y, r, f.tier, f.opacity);

        // Skill label with dark backdrop for readability
        ctx.globalAlpha = f.opacity;
        ctx.font = fontForTier(f.tier);
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';

        const maxWidth = r * 1.9;

        // Word-wrap: greedily fill lines within maxWidth
        const words = f.label.split(' ');
        const lines: string[] = [];
        let currentLine = words[0] || '';
        for (let w = 1; w < words.length; w++) {
            const candidate = currentLine + ' ' + words[w];
            if (ctx.measureText(candidate).width <= maxWidth) {
                currentLine = candidate;
            } else {
                lines.push(currentLine);
                currentLine = words[w];
            }
        }
        lines.push(currentLine);

        const lineHeight = f.tier <= 1 ? 13 : (f.tier <= 3 ? 15 : 18);
        const totalH = lines.length * lineHeight;
        const labelY = f.y;
        const startY = labelY - totalH / 2 + lineHeight / 2;

        // Dark rounded backdrop behind text
        const textMetrics = lines.map(l => ctx.measureText(l).width);
        const maxTextW = Math.min(Math.max(...textMetrics) + 12, maxWidth + 12);
        const padY = 4;
        ctx.globalAlpha = f.opacity * 0.82;
        ctx.fillStyle = '#000000';
        const bgH = totalH + padY * 2;
        const bgY = labelY - bgH / 2;
        const bgR = Math.min(6, bgH / 2);
        ctx.beginPath();
        ctx.roundRect(f.x - maxTextW / 2, bgY, maxTextW, bgH, bgR);
        ctx.fill();

        // Text
        ctx.globalAlpha = f.opacity;
        ctx.fillStyle = '#ffffff';
        for (let i = 0; i < lines.length; i++) {
            ctx.fillText(lines[i], f.x, startY + i * lineHeight, maxWidth);
        }

        ctx.restore();
    }

    // ─── Draw drop preview ghost ───
    function drawPreview() {
        if (previewX === null || !nextDropReady) return;
        ctx.save();

        const t = TIERS[previewTier];
        const py = bowl.y - t.radius - 15;

        // Dashed drop line
        ctx.globalAlpha = 0.25;
        ctx.setLineDash([4, 6]);
        ctx.strokeStyle = t.stroke;
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(previewX, py + t.radius);
        ctx.lineTo(previewX, bowl.y + 20);
        ctx.stroke();
        ctx.setLineDash([]);

        // Ghost fruit shape
        drawFruitShape(previewX, py, t.radius, previewTier, 0.3);

        // Label
        ctx.globalAlpha = 0.4;
        ctx.font = fontForTier(previewTier);
        ctx.fillStyle = '#ffffff';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(previewLabel, previewX, py, t.radius * 1.6);

        ctx.restore();
    }

    // ─── Draw particles ───
    function drawParticles() {
        for (const p of particles) {
            ctx.save();
            ctx.globalAlpha = p.life;
            ctx.shadowColor = p.color;
            ctx.shadowBlur = 8;
            ctx.fillStyle = p.color;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
        }
    }

    function draw() {
        ctx.clearRect(0, 0, W, H);
        drawBowl();
        drawPreview();
        for (const f of fruits) {
            if (f.alive) drawFruit(f);
        }
        drawParticles();
    }

    function start() {
        if (running) return;
        running = true;
        fruits.length = 0;
        particles.length = 0;
        lastAutoDrop = 0;
        ageCounter = 0;
        tierSpawnIdx.fill(0);
        userControlActive = false;
        prepareNextDrop();
        resize();

        // Pre-populate bowl with a few fruits so it's not empty at start
        const initialFruits = [
            { tier: 0, xOff: -0.25 },
            { tier: 1, xOff: 0.15 },
            { tier: 2, xOff: -0.10 },
            { tier: 0, xOff: 0.30 },
            { tier: 3, xOff: -0.05 },
        ];
        for (const { tier, xOff } of initialFruits) {
            const fx = bowl.cx + xOff * bowl.w;
            const fy = bowl.y - TIERS[tier].radius - 20 - Math.random() * 30;
            const f = createFruit(fx, fy, tier, skillForTier(tier));
            f.vy = 40 + Math.random() * 30;
            f.vx = (Math.random() - 0.5) * 40;
            fruits.push(f);
        }

        let prev = performance.now();

        function tick(now: number) {
            const dt = Math.min((now - prev) / 1000, DT_CAP);
            prev = now;

            // Auto-pilot logic
            if (!userControlActive || (now - lastUserAction > IDLE_TIMEOUT)) {
                userControlActive = false;
                previewX = null;
                if (now - lastAutoDrop > AUTO_DROP_INTERVAL) {
                    autoDropFruit();
                    lastAutoDrop = now;
                }
            }

            // Overflow recycling: fade oldest/smallest when over limit
            const aliveNonMerging = fruits.filter(f => f.alive && !f.merging && !f.grabbed);
            if (aliveNonMerging.length > MAX_FRUITS) {
                const sorted = aliveNonMerging.sort((a, b) => {
                    if (a.tier !== b.tier) return a.tier - b.tier; // smallest first
                    return a.age - b.age; // oldest first
                });
                const excess = aliveNonMerging.length - MAX_FRUITS;
                for (let k = 0; k < excess; k++) {
                    if (sorted[k].opacity === 1) sorted[k].opacity = 0.99;
                }
            }

            // GC dead fruits
            for (let k = fruits.length - 1; k >= 0; k--) {
                if (!fruits[k].alive) fruits.splice(k, 1);
            }

            step(dt);
            draw();

            animId = requestAnimationFrame(tick);
        }
        animId = requestAnimationFrame(tick);
    }

    function stop() {
        if (animId !== null) { cancelAnimationFrame(animId); animId = null; }
        running = false;
        fruits.length = 0;
        particles.length = 0;
        dragFruit = null;
        previewX = null;
        ctx.clearRect(0, 0, W, H);
    }

    let resizeTimer: number;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
            if (running) resize();
        }, 100);
    });

    // Watch reveal visibility to start/stop
    const revealSibling = pit.parentElement?.querySelector('.reveal') ||
                          pit.nextElementSibling?.querySelector('.reveal');
    if (revealSibling) {
        const mo = new MutationObserver(() => {
            if (revealSibling.classList.contains('visible')) {
                if (!running) start();
            } else {
                if (running) stop();
            }
        });
        mo.observe(revealSibling, { attributes: true, attributeFilter: ['class'] });
        if (revealSibling.classList.contains('visible')) start();
    }
})();
</script>
